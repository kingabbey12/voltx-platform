{
  "name": "@voltx/cli",
  "version": "0.1.0",
  "description": "Official command-line tool for the Voltx public API",
  "license": "MIT",
  "type": "module",
  "bin": {
    "voltx": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
