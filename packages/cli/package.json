    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@voltx/sdk": "file:../sdk-typescript",
    "commander": "^13.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
