{
  "name": "@voltx/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript SDK for the Voltx public API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:types": "node scripts/generate-types.mjs",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test test/client.test.ts test/resources.test.ts test/webhook-signature.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
