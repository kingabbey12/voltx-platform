# Base URL of the backend API, including its version prefix. Required in
# every environment — there is no default; see src/config/env.ts.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Stripe's publishable (client-side, non-secret) key — enables the "Add
# payment method" flow on the Billing > Payment Methods page. Optional:
# when unset, that page shows a clear "Stripe is not configured" message
# instead of a broken card form, mirroring the backend's own graceful
# degradation when STRIPE_API_KEY is unset.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
