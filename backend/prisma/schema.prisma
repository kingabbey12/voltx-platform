/// v2.2 Enterprise Identity — SSO protocol and status.
enum IdentityProviderProtocol {
  SAML
  OIDC
}

/// v2.2 Enterprise Identity — one preset per named IdP in the spec, plus a
/// GENERIC fallback for any other SAML/OIDC-compliant provider. A preset is
/// purely a set of sane defaults/attribute-mapping hints applied when an
/// admin picks it in the setup wizard — it does not change the underlying
/// protocol handling, which is identical for every preset sharing a protocol.
enum IdentityProviderPreset {
  GENERIC
  ENTRA_ID
  OKTA
  GOOGLE_WORKSPACE
  ONELOGIN
  PING_IDENTITY
}

enum IdentityProviderStatus {
  DRAFT
  ACTIVE
  DISABLED
}

/// v2.2 Enterprise Identity — one configured identity provider for an
/// organization. An organization may have multiple (e.g. SAML for one
/// subsidiary's Okta tenant, OIDC for another's Entra ID). Exactly one of
/// `samlConfiguration`/`oidcConfiguration` is populated, matching `protocol`.
model IdentityProvider {
  id                     String                   @id @default(uuid()) @db.Uuid
  organizationId         String                   @map("organization_id") @db.Uuid
  name                   String
  protocol               IdentityProviderProtocol
  preset                 IdentityProviderPreset   @default(GENERIC)
  status                 IdentityProviderStatus   @default(DRAFT)
  isDefault              Boolean                  @default(false) @map("is_default")
  jitProvisioningEnabled Boolean                  @default(true) @map("jit_provisioning_enabled")
  /// Role key (e.g. "member") assigned to a JIT-provisioned membership when
  /// no rule in roleMappingRules matches the assertion/claims.
  defaultRoleKey         String                   @default("member") @map("default_role_key")
  /// Array of { sourceValue: string, roleKey: string } — sourceValue is
  /// matched against the IdP group/role attribute configured per-provider.
  roleMappingRules       Json                     @default("[]") @map("role_mapping_rules")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  deletedAt              DateTime?                @map("deleted_at")
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  samlConfiguration      SamlConfiguration?
  oidcConfiguration      OidcConfiguration?
  provisionedMemberships Membership[]             @relation("MembershipProvisionedBy")
  scimTokens             ScimToken[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("identity_providers")
}

/// v2.2 Enterprise Identity — SAML 2.0 configuration for one IdentityProvider.
/// idpCertificate/metadataXml hold the IdP's own public signing certificate
/// (encrypted at rest via EncryptionService — this is the IdP's public key,
/// encrypted anyway so a DB dump doesn't hand an attacker every configured
/// IdP's trust material in plaintext for easy reconnaissance).
model SamlConfiguration {
  id                      String           @id @default(uuid()) @db.Uuid
  identityProviderId      String           @unique @map("identity_provider_id") @db.Uuid
  idpEntityId             String           @map("idp_entity_id")
  idpSsoUrl               String           @map("idp_sso_url")
  idpSloUrl               String?          @map("idp_slo_url")
  idpCertificate          String           @map("idp_certificate")
  idpCertificateExpiresAt DateTime?        @map("idp_certificate_expires_at")
  spEntityId              String           @map("sp_entity_id")
  signatureAlgorithm      String           @default("sha256") @map("signature_algorithm")
  wantAssertionsSigned    Boolean          @default(true) @map("want_assertions_signed")
  /// Raw imported metadata XML, kept for re-parsing/troubleshooting — not
  /// itself parsed again at request time (idpEntityId/idpSsoUrl/idpCertificate
  /// above are extracted once at import time and are what's actually used).
  metadataXml             String?          @map("metadata_xml")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")
  identityProvider        IdentityProvider @relation(fields: [identityProviderId], references: [id], onDelete: Cascade)

  @@map("saml_configurations")
}

/// v2.2 Enterprise Identity — OIDC configuration for one IdentityProvider.
model OidcConfiguration {
  id                    String           @id @default(uuid()) @db.Uuid
  identityProviderId    String           @unique @map("identity_provider_id") @db.Uuid
  issuer                String
  clientId              String           @map("client_id")
  clientSecret          String           @map("client_secret")
  authorizationEndpoint String?          @map("authorization_endpoint")
  tokenEndpoint         String?          @map("token_endpoint")
  userinfoEndpoint      String?          @map("userinfo_endpoint")
  jwksUri               String?          @map("jwks_uri")
  scopes                String[]         @default(["openid", "email", "profile"])
  claimsMapping         Json             @default("{}") @map("claims_mapping")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  identityProvider      IdentityProvider @relation(fields: [identityProviderId], references: [id], onDelete: Cascade)

  @@map("oidc_configurations")
}

/// v2.2 SCIM 2.0 — bearer-token status for inbound provisioning.
enum ScimTokenStatus {
  ACTIVE
  REVOKED
}

/// v2.2 SCIM 2.0 — a bearer token an organization's IdP uses to call
/// `/scim/v2/*`. Optionally linked to the IdentityProvider it belongs to
/// (purely informational — auth is by tokenHash, exactly like
/// RefreshTokenRepository's hash-and-compare convention, not by the link).
model ScimToken {
  id                 String             @id @default(uuid()) @db.Uuid
  organizationId     String             @map("organization_id") @db.Uuid
  identityProviderId String?            @map("identity_provider_id") @db.Uuid
  name               String
  tokenHash          String             @unique @map("token_hash")
  status             ScimTokenStatus    @default(ACTIVE)
  expiresAt          DateTime?          @map("expires_at")
  lastUsedAt         DateTime?          @map("last_used_at")
  revokedAt          DateTime?          @map("revoked_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  identityProvider   IdentityProvider?  @relation(fields: [identityProviderId], references: [id], onDelete: SetNull)
  provisionJobs      ScimProvisionJob[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("scim_tokens")
}

/// v2.2 SCIM 2.0 — one provisioning operation, for audit/troubleshooting.
enum ScimOperationType {
  CREATE_USER
  UPDATE_USER
  DEACTIVATE_USER
  GROUP_SYNC
}

enum ScimProvisionJobStatus {
  SUCCESS
  FAILED
}

model ScimProvisionJob {
  id                 String                 @id @default(uuid()) @db.Uuid
  organizationId     String                 @map("organization_id") @db.Uuid
  scimTokenId        String                 @map("scim_token_id") @db.Uuid
  operation          ScimOperationType
  /// The IdP's own identifier for the resource being provisioned (SCIM
  /// externalId, or the SCIM resource id on update/deactivate) — not
  /// persisted anywhere else, kept here purely for audit/troubleshooting.
  externalId         String?                @map("external_id")
  targetUserId       String?                @map("target_user_id") @db.Uuid
  targetMembershipId String?                @map("target_membership_id") @db.Uuid
  status             ScimProvisionJobStatus
  requestPayload     Json                   @map("request_payload")
  responsePayload    Json?                  @map("response_payload")
  errorMessage       String?                @map("error_message")
  createdAt          DateTime               @default(now()) @map("created_at")
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scimToken          ScimToken              @relation(fields: [scimTokenId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([scimTokenId])
  @@map("scim_provision_jobs")
}

/// v2.2 Enterprise Organization Hierarchy — intra-tenant business unit,
/// optionally self-nesting. Purely organizational metadata for tagging
/// memberships; carries no access/permission implication of its own.
model BusinessUnit {
  id                   String         @id @default(uuid()) @db.Uuid
  organizationId       String         @map("organization_id") @db.Uuid
  name                 String
  parentBusinessUnitId String?        @map("parent_business_unit_id") @db.Uuid
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  organization         Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentBusinessUnit   BusinessUnit?  @relation("BusinessUnitHierarchy", fields: [parentBusinessUnitId], references: [id], onDelete: SetNull)
  childBusinessUnits   BusinessUnit[] @relation("BusinessUnitHierarchy")
  memberships          Membership[]

  @@index([organizationId])
  @@index([parentBusinessUnitId])
  @@map("business_units")
}

/// v2.2 Enterprise Organization Hierarchy — intra-tenant department, optionally self-nesting.
model Department {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @map("organization_id") @db.Uuid
  name               String
  parentDepartmentId String?      @map("parent_department_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments   Department[] @relation("DepartmentHierarchy")
  teams              Team[]
  memberships        Membership[]

  @@index([organizationId])
  @@index([parentDepartmentId])
  @@map("departments")
}

/// v2.2 Enterprise Organization Hierarchy — intra-tenant team, optionally scoped to a department.
model Team {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  departmentId   String?      @map("department_id") @db.Uuid
  name           String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  memberships    Membership[]

  @@index([organizationId])
  @@index([departmentId])
  @@map("teams")
}

/// v2.2 Enterprise Organization Hierarchy — intra-tenant cost center, for
/// financial/reporting tagging. Not linked to Membership directly (a
/// cost center tags a BusinessUnit/Department, not an individual member,
/// in the common accounting convention) — kept as an independent,
/// org-scoped lookup table.
model CostCenter {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  code           String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("cost_centers")
}

/// v2.2 Compliance Center — output format for a generated AuditExport file.
enum AuditExportFormat {
  CSV
  JSON
}

/// v2.2 Compliance Center — lifecycle of an AuditExport job. Generation
/// happens synchronously within the request in this implementation (audit
/// log volumes here don't warrant an async worker), but the status column
/// exists so a future move to a background job is a non-breaking change.
enum AuditExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// v2.2 Compliance Center — a single request to export an organization's
/// AuditLog rows (for a date range) to a file in the existing
/// attachments StorageProvider, for external legal/compliance review.
model AuditExport {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  requestedBy    String            @map("requested_by") @db.Uuid
  fromDate       DateTime          @map("from_date")
  toDate         DateTime          @map("to_date")
  format         AuditExportFormat @default(JSON)
  status         AuditExportStatus @default(PENDING)
  storageKey     String?           @map("storage_key")
  rowCount       Int?              @map("row_count")
  errorMessage   String?           @map("error_message")
  createdAt      DateTime          @default(now()) @map("created_at")
  completedAt    DateTime?         @map("completed_at")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("audit_exports")
}

/// v2.2 Compliance Center — whether a hold is currently blocking deletion.
enum LegalHoldStatus {
  ACTIVE
  RELEASED
}

/// v2.2 Compliance Center — a legal/litigation hold that blocks GDPR
/// erasure for its target while ACTIVE. `targetUserId` scopes the hold to
/// one data subject within the organization; a null `targetUserId` is an
/// organization-wide hold that blocks erasure for every user in the org
/// (e.g. a litigation matter affecting the whole tenant). `scope` carries
/// free-form context (matter name, legal reference, resource-type
/// restrictions) for audit/reporting.
model LegalHold {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  name           String
  reason         String
  targetUserId   String?         @map("target_user_id") @db.Uuid
  scope          Json            @default("{}")
  status         LegalHoldStatus @default(ACTIVE)
  createdBy      String          @map("created_by") @db.Uuid
  releasedBy     String?         @map("released_by") @db.Uuid
  releasedAt     DateTime?       @map("released_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([targetUserId])
  @@map("legal_holds")
}

/// v2.2 Compliance Center — resource families a RetentionPolicy can target.
/// Deliberately limited to resources this module actually knows how to
/// sweep (see ComplianceRetentionService) rather than every model in the
/// schema — extend alongside the sweep logic, not ahead of it.
enum RetentionResourceType {
  AUDIT_LOG
  CONVERSATION
  NOTIFICATION
  ATTACHMENT
}

enum RetentionAction {
  DELETE
  ANONYMIZE
}

/// v2.2 Compliance Center — org-configured data-retention rule: "resource
/// of type X older than retentionDays gets action Y." CRUD only in this
/// phase (no scheduled sweep worker yet — see module report for scoping).
model RetentionPolicy {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  resourceType   RetentionResourceType @map("resource_type")
  retentionDays  Int                   @map("retention_days")
  action         RetentionAction
  isActive       Boolean               @default(true) @map("is_active")
  createdBy      String                @map("created_by") @db.Uuid
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, resourceType])
  @@index([organizationId])
  @@map("retention_policies")
}

/// v2.2 Compliance Center — append-only history of a user's consent
/// decisions. Each grant/revoke action inserts a new row rather than
/// mutating a prior one, so the full consent history for a
/// (userId, consentType) pair is reconstructable for audit purposes.
/// consentType is intentionally a free-form string, not an enum — consent
/// categories are a product/legal concern that evolves independently of
/// deploys (e.g. "marketing_emails", "data_processing", "cookies_analytics").
model ConsentRecord {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  consentType    String       @map("consent_type")
  granted        Boolean
  grantedAt      DateTime?    @map("granted_at")
  revokedAt      DateTime?    @map("revoked_at")
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([userId, consentType])
  @@map("consent_records")
}

/// v2.2 Security Center — one stable "device/browser" login instance. Created
/// once at login (or after a successful MFA challenge verify); refresh-token
/// rotation reuses the same Session rather than creating a new one, so
/// revoking a Session here immediately rejects every RefreshToken under it
/// (see RefreshToken.sessionId). Org-scoped in the domain sense only — like
/// IdentityProvider, not auto-scoped by the tenant Prisma extension, so every
/// repository method filters by organizationId explicitly.
model Session {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @map("user_id") @db.Uuid
  organizationId    String         @map("organization_id") @db.Uuid
  deviceFingerprint String?        @map("device_fingerprint")
  ipAddress         String?        @map("ip_address")
  userAgent         String?        @map("user_agent")
  lastActiveAt      DateTime       @default(now()) @map("last_active_at")
  revokedAt         DateTime?      @map("revoked_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens     RefreshToken[]

  @@index([userId])
  @@index([organizationId])
  @@index([userId, revokedAt])
  @@map("sessions")
}

/// v2.2 Security Center — a device a user has explicitly chosen to "remember"
/// past MFA for, until `trustedUntil`. Consulted by AuthService.login() to
/// skip an otherwise-required MFA challenge for that one (userId,
/// deviceFingerprint) pair while the window is still open.
model TrustedDevice {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  deviceFingerprint String       @map("device_fingerprint")
  label             String?
  lastSeenAt        DateTime     @default(now()) @map("last_seen_at")
  trustedUntil      DateTime     @map("trusted_until")
  revokedAt         DateTime?    @map("revoked_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@index([organizationId])
  @@map("trusted_devices")
}

/// v2.2 Security Center — a long-lived, org-scoped credential usable as a JWT
/// alternative for machine-to-machine callers (see ApiKeyGuard). Only
/// `keyHash` (sha256, same hash-and-compare convention as RefreshToken) is
/// ever stored — the raw key is shown to the caller exactly once, at
/// creation. `scopedPermissions` must be a subset of the org's real
/// permission keys, validated at creation time.
model ApiKey {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  createdByUserId   String?      @map("created_by_user_id") @db.Uuid
  name              String
  keyHash           String       @unique @map("key_hash")
  /// Non-secret hint shown in the UI so an admin can tell keys apart
  /// without ever re-displaying the secret (e.g. "vk_live_ab12...").
  keyPrefix         String       @map("key_prefix")
  scopedPermissions String[]     @default([]) @map("scoped_permissions")
  expiresAt         DateTime?    @map("expires_at")
  lastUsedAt        DateTime?    @map("last_used_at")
  revokedAt         DateTime?    @map("revoked_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("api_keys")
}

/// v2.2 White-label — one branding theme per organization (1:1). Logo/
/// favicon/login-background are stored via the existing attachments
/// StorageProvider (storage keys only, not raw bytes) — the public
/// branding endpoint mints a fresh signed URL per read rather than
/// storing a permanent public URL, so nothing here needs a new storage
/// abstraction. `emailTemplateOverrides` is a free-form Json map (e.g.
/// `{ "invitation": { "subject": "...", "footerHtml": "..." } }`) — which
/// keys are honored is decided by the email-sending code, not this model.
model BrandTheme {
  id                        String       @id @default(uuid()) @db.Uuid
  organizationId            String       @unique @map("organization_id") @db.Uuid
  logoStorageKey            String?      @map("logo_storage_key")
  faviconStorageKey         String?      @map("favicon_storage_key")
  loginBackgroundStorageKey String?      @map("login_background_storage_key")
  primaryColor              String?      @map("primary_color")
  secondaryColor            String?      @map("secondary_color")
  accentColor               String?      @map("accent_color")
  loginHeadline             String?      @map("login_headline")
  loginSubtext              String?      @map("login_subtext")
  emailTemplateOverrides    Json         @default("{}") @map("email_template_overrides")
  createdAt                 DateTime     @default(now()) @map("created_at")
  updatedAt                 DateTime     @updatedAt @map("updated_at")
  organization              Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("brand_themes")
}

/// v2.2 White-label — domain-ownership verification status for a
/// custom login domain. Verified via a real DNS TXT record lookup
/// (src/modules/branding/utils/dns-verification.util.ts) against
/// `verificationToken`; no in-app ACME/TLS issuance happens anywhere —
/// `sslStatus` only ever reflects state fed in by an external process
/// (documented as a deployment/infra step, not built by this phase).
enum CustomDomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum CustomDomainSslStatus {
  PENDING
  ACTIVE
  FAILED
}

model CustomDomain {
  id                 String                         @id @default(uuid()) @db.Uuid
  organizationId     String                         @map("organization_id") @db.Uuid
  domain             String                         @unique
  verificationToken  String                         @map("verification_token")
  verificationStatus CustomDomainVerificationStatus @default(PENDING) @map("verification_status")
  sslStatus          CustomDomainSslStatus          @default(PENDING) @map("ssl_status")
  verifiedAt         DateTime?                      @map("verified_at")
  createdAt          DateTime                       @default(now()) @map("created_at")
  updatedAt          DateTime                       @updatedAt @map("updated_at")
  organization       Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("custom_domains")
}

/// v2.2 Platform Console — a system- or organization-level incident
/// raised by (or on behalf of) a monitoring signal (queue backlog,
/// job-failure spike, delivery-failure rate, ...). `organizationId` is
/// nullable because some alerts are platform-wide (e.g. Redis
/// unreachable) rather than about any one tenant. No relation to
/// Organization/User (same unscoped-FK convention as
/// BackgroundJobFailure.organizationId / SubscriptionChange.initiatedBy)
/// since this is read cross-tenant by platform admins only.
enum PlatformAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum PlatformAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model PlatformAlert {
  id               String                @id @default(uuid()) @db.Uuid
  severity         PlatformAlertSeverity
  category         String
  status           PlatformAlertStatus   @default(OPEN)
  title            String
  description      String?               @db.Text
  sourceMetadata   Json                  @default("{}") @map("source_metadata")
  organizationId   String?               @map("organization_id") @db.Uuid
  acknowledgedById String?               @map("acknowledged_by_id") @db.Uuid
  acknowledgedAt   DateTime?             @map("acknowledged_at")
  resolvedById     String?               @map("resolved_by_id") @db.Uuid
  resolvedAt       DateTime?             @map("resolved_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([organizationId])
  @@index([createdAt])
  @@map("platform_alerts")
}

/// v2.2 Platform Console — a platform-wide feature flag with an optional
/// per-organization override. `organizationOverrides` is a Json map of
/// `{ [organizationId]: value }` rather than a join table: flag
/// resolution always loads the single flag row and does a JS object
/// lookup, and the platform-wide flag count is expected to stay small
/// (tens, not thousands), so there's no query-planning benefit to a
/// relational join table here. Deliberately distinct from v2.1's billing
/// Feature/FeatureLimit entitlement models (those gate metered plan
/// limits; this gates code paths/rollout, unrelated to billing).
enum FeatureFlagType {
  BOOLEAN
  STRING
  NUMBER
  JSON
}

model FeatureFlag {
  id                    String          @id @default(uuid()) @db.Uuid
  key                   String          @unique
  name                  String
  description           String?
  type                  FeatureFlagType @default(BOOLEAN)
  defaultValue          Json            @map("default_value")
  organizationOverrides Json            @default("{}") @map("organization_overrides")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  @@map("feature_flags")
}

/// v2.2 Customer Success (Phase 9) — a platform admin's time-boxed,
/// mandatory-reason-logged impersonation of one organization. Unlike a
/// normal login, this issues ONLY a short-lived access token (no
/// refresh token, no Session row) — reusing the same JwtService/payload
/// shape as AuthService.issueTokens but deliberately not the refresh-
/// token/session side effects, since a leaked long-lived refresh token
/// would be a much worse footgun for a support session than simply
/// requiring a fresh, re-audited start once 45 minutes pass.
/// `supportMembershipId` is set only when start() had to JIT-create a
/// Membership for the admin in the target org (role 'admin', so support
/// sees exactly what the org's own admin sees) — end()/expire() deletes
/// exactly that row, never a genuine pre-existing membership the admin
/// might coincidentally already hold. Revocation is instant and requires
/// no token blocklist: JwtAccessStrategy checks this row's status/expiry
/// live whenever a token carries a `supportSessionId` claim.
enum SupportSessionStatus {
  ACTIVE
  ENDED
  EXPIRED
}

model SupportSession {
  id                   String               @id @default(uuid()) @db.Uuid
  platformAdminUserId  String               @map("platform_admin_user_id") @db.Uuid
  targetOrganizationId String               @map("target_organization_id") @db.Uuid
  reason               String               @db.Text
  status               SupportSessionStatus @default(ACTIVE)
  supportMembershipId  String?              @map("support_membership_id") @db.Uuid
  expiresAt            DateTime             @map("expires_at")
  endedAt              DateTime?            @map("ended_at")
  endedById            String?              @map("ended_by_id") @db.Uuid
  createdAt            DateTime             @default(now()) @map("created_at")

  @@index([platformAdminUserId])
  @@index([targetOrganizationId])
  @@index([status])
  @@map("support_sessions")
}

/// v2.2 Customer Success (Phase 9) — a platform admin's freeform note on
/// an organization, e.g. context left for the next support agent. Not
/// tied to any single SupportSession since a note is often useful across
/// several separate support interactions with the same organization.
model SupportNote {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  authorId       String   @map("author_id") @db.Uuid
  note           String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("support_notes")
}

/// v2.3 Developer Platform (Phase 1) — a user-scoped (not org-scoped)
/// bearer credential for an individual developer's own scripts/tools,
/// distinct from ApiKey (org-scoped, created by any member with
/// security.apikey.manage). Same hash-and-compare convention as ApiKey/
/// RefreshToken (see security-hash.util.ts's sha256Hex). Since a user can
/// belong to many organizations, a PAT-authenticated request must state
/// which org it's acting in (see PersonalAccessTokenGuard's
/// X-Organization-Id header) — the token itself carries no single org.
model PersonalAccessToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  name              String
  tokenHash         String    @unique @map("token_hash")
  /// Non-secret hint (e.g. "vpat_ab12cd34...") shown in the UI so a user
  /// can tell tokens apart without the secret ever being re-displayed.
  tokenPrefix       String    @map("token_prefix")
  scopedPermissions String[]  @default([]) @map("scoped_permissions")
  expiresAt         DateTime? @map("expires_at")
  lastUsedAt        DateTime? @map("last_used_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("personal_access_tokens")
}

enum ServiceAccountStatus {
  ACTIVE
  SUSPENDED
}

/// v2.3 Developer Platform (Phase 1) — a non-human organization member for
/// machine-to-machine access. Deliberately backed by a real synthetic User
/// row (userId, type=SERVICE_ACCOUNT) + a real Membership rather than a
/// parallel permission system: ServiceAccountGuard resolves permissions by
/// calling the exact same AuthContextService.resolveCurrentUser() a human
/// JWT login uses, so role changes/permission grants apply identically and
/// immediately to service accounts with zero new authorization logic.
model ServiceAccount {
  id              String                @id @default(uuid()) @db.Uuid
  organizationId  String                @map("organization_id") @db.Uuid
  /// The synthetic User row this service account's Membership hangs off.
  userId          String                @unique @map("user_id") @db.Uuid
  name            String
  description     String?
  status          ServiceAccountStatus  @default(ACTIVE)
  createdByUserId String?               @map("created_by_user_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokens          ServiceAccountToken[]

  @@index([organizationId])
  @@map("service_accounts")
}

model ServiceAccountToken {
  id               String         @id @default(uuid()) @db.Uuid
  serviceAccountId String         @map("service_account_id") @db.Uuid
  name             String
  tokenHash        String         @unique @map("token_hash")
  tokenPrefix      String         @map("token_prefix")
  expiresAt        DateTime?      @map("expires_at")
  lastUsedAt       DateTime?      @map("last_used_at")
  revokedAt        DateTime?      @map("revoked_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@index([serviceAccountId])
  @@map("service_account_tokens")
}

enum OAuthApplicationStatus {
  ACTIVE
  SUSPENDED
}

/// v2.3 Developer Platform (Phase 2) — a third-party application registered
/// to act as an OAuth 2.0 client against Voltx's own authorization server.
/// clientId is non-secret (safe to embed in a public app); clientSecretHash
/// follows the exact hash-and-compare convention every other credential in
/// this codebase uses. `scopes` is the maximum set of permission keys this
/// app can ever request — the authorizing user's own current permissions
/// further narrow what's actually granted at consent time (same
/// can't-exceed-caller rule as ApiKey/PersonalAccessToken/ServiceAccount).
model OAuthApplication {
  id                 String                 @id @default(uuid()) @db.Uuid
  organizationId     String                 @map("organization_id") @db.Uuid
  ownerUserId        String                 @map("owner_user_id") @db.Uuid
  name               String
  description        String?
  logoUrl            String?                @map("logo_url")
  clientId           String                 @unique @map("client_id")
  clientSecretHash   String                 @map("client_secret_hash")
  /// Non-secret hint (e.g. "vcs_ab12cd34...") shown in the UI, same
  /// convention as every other credential's *Prefix column.
  clientSecretPrefix String                 @map("client_secret_prefix")
  scopes             String[]               @default([])
  status             OAuthApplicationStatus @default(ACTIVE)
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  redirectUris       OAuthRedirectUri[]
  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]
  refreshTokens      OAuthRefreshToken[]

  @@index([organizationId])
  @@map("oauth_applications")
}

/// Validated at registration time via OutboundHttpGuardService — the exact
/// same private-IP/DNS-resolution SSRF check already used for AI tool
/// outbound requests, since a redirect URI is just as attacker-influenced.
model OAuthRedirectUri {
  id            String   @id @default(uuid()) @db.Uuid
  applicationId String   @map("application_id") @db.Uuid
  uri           String
  createdAt     DateTime @default(now()) @map("created_at")

  application OAuthApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, uri])
  @@index([applicationId])
  @@map("oauth_redirect_uris")
}

/// Single-use, short-lived (~60s) authorization grant issued after user
/// consent. codeHash follows the standard hash-and-compare convention;
/// consumedAt enforces single-use atomically (see
/// OAuthTokenService.exchangeAuthorizationCode, which consumes it via a
/// conditional updateMany so a replayed code can never be redeemed twice).
model OAuthAuthorizationCode {
  id                        String    @id @default(uuid()) @db.Uuid
  applicationId             String    @map("application_id") @db.Uuid
  authorizingUserId         String    @map("authorizing_user_id") @db.Uuid
  authorizingOrganizationId String    @map("authorizing_organization_id") @db.Uuid
  codeHash                  String    @unique @map("code_hash")
  redirectUri               String    @map("redirect_uri")
  scopes                    String[]  @default([])
  /// PKCE (RFC 7636) — S256 is the only supported method; "plain" is
  /// deliberately rejected at issuance (see OAuthAuthorizationService).
  codeChallenge             String    @map("code_challenge")
  codeChallengeMethod       String    @map("code_challenge_method")
  expiresAt                 DateTime  @map("expires_at")
  consumedAt                DateTime? @map("consumed_at")
  createdAt                 DateTime  @default(now()) @map("created_at")

  application OAuthApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("oauth_authorization_codes")
}

model OAuthAccessToken {
  id                        String    @id @default(uuid()) @db.Uuid
  applicationId             String    @map("application_id") @db.Uuid
  authorizingUserId         String    @map("authorizing_user_id") @db.Uuid
  authorizingOrganizationId String    @map("authorizing_organization_id") @db.Uuid
  tokenHash                 String    @unique @map("token_hash")
  tokenPrefix               String    @map("token_prefix")
  scopes                    String[]  @default([])
  expiresAt                 DateTime  @map("expires_at")
  revokedAt                 DateTime? @map("revoked_at")
  createdAt                 DateTime  @default(now()) @map("created_at")

  application  OAuthApplication   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  refreshToken OAuthRefreshToken?

  @@index([applicationId])
  @@index([authorizingUserId])
  @@map("oauth_access_tokens")
}

/// Rotated on every use (see OAuthTokenService.refresh): the presented
/// refresh token is revoked and a brand-new access/refresh pair is issued,
/// rather than the same refresh token being reusable indefinitely.
model OAuthRefreshToken {
  id                        String    @id @default(uuid()) @db.Uuid
  applicationId             String    @map("application_id") @db.Uuid
  accessTokenId             String    @unique @map("access_token_id") @db.Uuid
  authorizingUserId         String    @map("authorizing_user_id") @db.Uuid
  authorizingOrganizationId String    @map("authorizing_organization_id") @db.Uuid
  tokenHash                 String    @unique @map("token_hash")
  scopes                    String[]  @default([])
  expiresAt                 DateTime  @map("expires_at")
  revokedAt                 DateTime? @map("revoked_at")
  createdAt                 DateTime  @default(now()) @map("created_at")

  application OAuthApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  accessToken OAuthAccessToken @relation(fields: [accessTokenId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("oauth_refresh_tokens")
}

enum WebhookEndpointStatus {
  ACTIVE
  SUSPENDED
}

/// v2.3 Developer Platform (Phase 3) — a developer-registered HTTPS
/// destination that receives signed, retried deliveries of the event
/// types it subscribes to (see webhook-event.catalog.ts). `url` is
/// validated at registration time via OutboundHttpGuardService, the same
/// SSRF check as an OAuth redirect URI — a webhook URL is exactly as
/// attacker-influenced. `encryptedSecret` is AES-256-GCM at rest
/// (EncryptionService) and decrypted only at delivery time to compute the
/// HMAC signature; it is never re-displayed after creation.
model WebhookEndpoint {
  id              String                @id @default(uuid()) @db.Uuid
  organizationId  String                @map("organization_id") @db.Uuid
  url             String
  description     String?
  encryptedSecret String                @map("encrypted_secret")
  eventTypes      String[]              @default([]) @map("event_types")
  status          WebhookEndpointStatus @default(ACTIVE)
  createdByUserId String?               @map("created_by_user_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId])
  @@map("webhook_endpoints")
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCEEDED
  FAILED
  EXHAUSTED
}

/// One row per delivery *attempt series* for one event occurrence — a
/// manual replay (see WebhookEndpointController) creates a brand-new row
/// rather than mutating an existing one, so the original delivery's
/// history is never overwritten.
model WebhookDelivery {
  id                 String                @id @default(uuid()) @db.Uuid
  endpointId         String                @map("endpoint_id") @db.Uuid
  eventType          String                @map("event_type")
  payload            Json
  status             WebhookDeliveryStatus @default(PENDING)
  responseStatusCode Int?                  @map("response_status_code")
  responseBody       String?               @map("response_body")
  attemptCount       Int                   @default(0) @map("attempt_count")
  deliveredAt        DateTime?             @map("delivered_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([status])
  @@map("webhook_deliveries")
}

enum MarketplaceAppStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  SUSPENDED
}

enum MarketplaceAppVersionStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

/// v2.3 Developer Platform (Phase 7) — a marketplace listing owned by its
/// developer organization. `status` reflects the app as a whole (does it
/// have any published version at all, is it suspended); each version has
/// its own independent review lifecycle (see MarketplaceAppVersionStatus).
model MarketplaceApp {
  id                      String               @id @default(uuid()) @db.Uuid
  developerOrganizationId String               @map("developer_organization_id") @db.Uuid
  name                    String
  description             String?
  category                String
  iconUrl                 String?              @map("icon_url")
  status                  MarketplaceAppStatus @default(DRAFT)
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  developerOrganization Organization              @relation("MarketplaceAppDeveloper", fields: [developerOrganizationId], references: [id], onDelete: Cascade)
  versions              MarketplaceAppVersion[]
  installs              MarketplaceInstall[]
  reviews               MarketplaceReview[]
  revenueShares         MarketplaceRevenueShare[]

  @@index([developerOrganizationId])
  @@index([status])
  @@map("marketplace_apps")
}

/// A single submission for review. `manifest` is the Phase 8 Extension
/// Framework manifest (declarative pages/widgets/nav/AI tools) — stored as
/// opaque JSON here since this phase only needs to persist and serve it,
/// not interpret it. `priceCents` of 0 means free (installs directly, no
/// Stripe involved); a positive value routes install through the Stripe
/// Connect purchase flow (see MarketplaceInstallService).
model MarketplaceAppVersion {
  id               String                      @id @default(uuid()) @db.Uuid
  appId            String                      @map("app_id") @db.Uuid
  version          String
  manifest         Json
  changelog        String?
  priceCents       Int                         @default(0) @map("price_cents")
  status           MarketplaceAppVersionStatus @default(DRAFT)
  reviewedByUserId String?                     @map("reviewed_by_user_id") @db.Uuid
  reviewedAt       DateTime?                   @map("reviewed_at")
  rejectionReason  String?                     @map("rejection_reason")
  createdAt        DateTime                    @default(now()) @map("created_at")
  updatedAt        DateTime                    @updatedAt @map("updated_at")

  app      MarketplaceApp       @relation(fields: [appId], references: [id], onDelete: Cascade)
  installs MarketplaceInstall[]

  // v2.3 Developer Platform (Phase 8) — materialized from `manifest` once
  // this version is approved (see ExtensionMaterializationService).
  customPages  ExtensionCustomPage[]
  customWidgets ExtensionCustomWidget[]
  navEntries   ExtensionCustomNavEntry[]
  aiTools      ExtensionAiTool[]

  @@unique([appId, version])
  @@index([appId])
  @@index([status])
  @@map("marketplace_app_versions")
}

enum MarketplaceInstallStatus {
  ACTIVE
  UNINSTALLED
}

/// One row per (app, installing organization) — the @@unique enforces
/// "installed at most once per org", matching a real app-store constraint.
model MarketplaceInstall {
  id                       String                   @id @default(uuid()) @db.Uuid
  appId                    String                   @map("app_id") @db.Uuid
  installingOrganizationId String                   @map("installing_organization_id") @db.Uuid
  installedVersionId       String                   @map("installed_version_id") @db.Uuid
  status                   MarketplaceInstallStatus @default(ACTIVE)
  installedByUserId        String                   @map("installed_by_user_id") @db.Uuid
  uninstalledAt            DateTime?                @map("uninstalled_at")
  createdAt                DateTime                 @default(now()) @map("created_at")

  app                    MarketplaceApp            @relation(fields: [appId], references: [id], onDelete: Cascade)
  installingOrganization Organization              @relation("MarketplaceInstallOrganization", fields: [installingOrganizationId], references: [id], onDelete: Cascade)
  installedVersion       MarketplaceAppVersion     @relation(fields: [installedVersionId], references: [id], onDelete: Restrict)
  reviews                MarketplaceReview[]
  revenueShares          MarketplaceRevenueShare[]

  @@unique([appId, installingOrganizationId])
  @@index([installingOrganizationId])
  @@map("marketplace_installs")
}

/// @@unique enforces one review per installing organization per app — a
/// real e-commerce review constraint, matching the plan's own requirement.
model MarketplaceReview {
  id                       String   @id @default(uuid()) @db.Uuid
  appId                    String   @map("app_id") @db.Uuid
  installId                String   @map("install_id") @db.Uuid
  installingOrganizationId String   @map("installing_organization_id") @db.Uuid
  rating                   Int
  comment                  String?
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  app     MarketplaceApp     @relation(fields: [appId], references: [id], onDelete: Cascade)
  install MarketplaceInstall @relation(fields: [installId], references: [id], onDelete: Cascade)

  @@unique([appId, installingOrganizationId])
  @@index([appId])
  @@map("marketplace_reviews")
}

enum DeveloperConnectOnboardingStatus {
  PENDING
  ONBOARDING
  COMPLETE
}

/// A developer organization's Stripe Connect Express account, used as the
/// `transfer_data.destination` for paid app purchases so revenue lands
/// with the developer directly (minus the platform's application fee)
/// rather than needing a separate manual payout step.
model DeveloperConnectAccount {
  id                       String                           @id @default(uuid()) @db.Uuid
  organizationId           String                           @unique @map("organization_id") @db.Uuid
  stripeConnectedAccountId String                           @unique @map("stripe_connected_account_id")
  onboardingStatus         DeveloperConnectOnboardingStatus @default(PENDING) @map("onboarding_status")
  payoutsEnabled           Boolean                          @default(false) @map("payouts_enabled")
  createdAt                DateTime                         @default(now()) @map("created_at")
  updatedAt                DateTime                         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("developer_connect_accounts")
}

/// One row per completed paid-app purchase. Amounts are always
/// server-computed from the MarketplaceAppVersion's own listed
/// `priceCents` at webhook-confirmation time — never trusted from client
/// input — so the platform fee can never be bypassed by a manipulated
/// client-supplied amount.
model MarketplaceRevenueShare {
  id                      String   @id @default(uuid()) @db.Uuid
  appId                   String   @map("app_id") @db.Uuid
  installId               String   @map("install_id") @db.Uuid
  purchaseAmountCents     Int      @map("purchase_amount_cents")
  platformFeeCents        Int      @map("platform_fee_cents")
  developerPayoutCents    Int      @map("developer_payout_cents")
  stripeCheckoutSessionId String   @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?  @map("stripe_payment_intent_id")
  createdAt               DateTime @default(now()) @map("created_at")

  app     MarketplaceApp     @relation(fields: [appId], references: [id], onDelete: Cascade)
  install MarketplaceInstall @relation(fields: [installId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@map("marketplace_revenue_shares")
}

// v2.3 Developer Platform (Phase 8) — Extension Framework. Declarative
// only: pages/widgets/nav are a fixed-component-palette JSON tree
// rendered by the web app's own generic ManifestRenderer, never
// arbitrary developer code; Custom AI Tools are HMAC-signed HTTPS calls
// to the developer's own endpoint (same threat model as an outbound
// webhook), invoked through the existing ToolRegistry.registerDynamicSource
// extension point. Rows here are materialized from a
// MarketplaceAppVersion's own `manifest` field once that version is
// approved (see ExtensionMaterializationService) — the manifest itself
// is validated at submission time (see manifest-validator.util.ts).

enum ExtensionWidgetPlacement {
  DASHBOARD
  CRM_SIDEBAR
}

model ExtensionCustomPage {
  id                      String   @id @default(uuid()) @db.Uuid
  marketplaceAppVersionId String   @map("marketplace_app_version_id") @db.Uuid
  path                    String
  manifest                Json
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  version MarketplaceAppVersion @relation(fields: [marketplaceAppVersionId], references: [id], onDelete: Cascade)

  @@unique([marketplaceAppVersionId, path])
  @@index([marketplaceAppVersionId])
  @@map("extension_custom_pages")
}

model ExtensionCustomWidget {
  id                      String                   @id @default(uuid()) @db.Uuid
  marketplaceAppVersionId String                   @map("marketplace_app_version_id") @db.Uuid
  placement               ExtensionWidgetPlacement
  manifest                Json
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  version MarketplaceAppVersion @relation(fields: [marketplaceAppVersionId], references: [id], onDelete: Cascade)

  @@index([marketplaceAppVersionId])
  @@index([placement])
  @@map("extension_custom_widgets")
}

model ExtensionCustomNavEntry {
  id                      String   @id @default(uuid()) @db.Uuid
  marketplaceAppVersionId String   @map("marketplace_app_version_id") @db.Uuid
  label                   String
  icon                    String?
  targetPath              String   @map("target_path")
  createdAt               DateTime @default(now()) @map("created_at")

  version MarketplaceAppVersion @relation(fields: [marketplaceAppVersionId], references: [id], onDelete: Cascade)

  @@index([marketplaceAppVersionId])
  @@map("extension_custom_nav_entries")
}

model ExtensionAiTool {
  id                      String   @id @default(uuid()) @db.Uuid
  marketplaceAppVersionId String   @map("marketplace_app_version_id") @db.Uuid
  name                    String
  description             String
  parametersSchema        Json     @map("parameters_schema")
  responseSchema          Json     @map("response_schema")
  endpointUrl             String   @map("endpoint_url")
  encryptedSigningSecret  String   @map("encrypted_signing_secret")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  version MarketplaceAppVersion @relation(fields: [marketplaceAppVersionId], references: [id], onDelete: Cascade)

  @@unique([marketplaceAppVersionId, name])
  @@index([marketplaceAppVersionId])
  @@map("extension_ai_tools")
}
