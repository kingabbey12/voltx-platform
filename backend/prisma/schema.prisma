generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum ToolExecutionStatus {
  RUNNING
  SUCCEEDED
  FAILED
  TIMED_OUT
}

enum AgentRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  TIMED_OUT
}

enum SalesCompanyStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum SalesLeadStatus {
  NEW
  QUALIFIED
  NURTURING
  DISQUALIFIED
  CONVERTED
}

enum SalesOpportunityStage {
  DISCOVERY
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum SalesActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
}

model Organization {
  id          String             @id @default(uuid()) @db.Uuid
  name        String
  slug        String             @unique
  logoUrl     String?            @map("logo_url")
  industry    String?
  country     String?
  timezone    String             @default("UTC")
  status      OrganizationStatus @default(ACTIVE)
  settings    Json               @default("{}")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")
  memberships Membership[]
  conversations Conversation[]
  memories    Memory[]
  agents      Agent[]
  salesCompanies    SalesCompany[]
  salesContacts     SalesContact[]
  salesLeads        SalesLead[]
  salesOpportunities SalesOpportunity[]
  salesActivities   SalesActivity[]

  @@index([status])
  @@map("organizations")
}

model User {
  id              String         @id @default(uuid()) @db.Uuid
  email           String         @unique
  passwordHash    String?        @map("password_hash")
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  avatarUrl       String?        @map("avatar_url")
  phoneNumber     String?        @map("phone_number")
  jobTitle        String?        @map("job_title")
  status          UserStatus     @default(ACTIVE)
  lastLoginAt     DateTime?      @map("last_login_at")
  emailVerifiedAt DateTime?      @map("email_verified_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  memberships       Membership[]
  refreshTokens     RefreshToken[]
  verificationTokens VerificationToken[]
  conversations      Conversation[]
  memories           Memory[]

  @@index([status])
  @@map("users")
}

model Conversation {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  title          String
  model          String
  provider       String
  pinned         Boolean   @default(false)
  archived       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]
  toolExecutions ToolExecution[]
  memories       Memory[]
  memoryAccesses MemoryAccess[]
  agentRuns      AgentRun[]

  @@index([organizationId])
  @@index([userId])
  @@index([archived])
  @@index([pinned])
  @@index([deletedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String
  metadata       Json         @default("{}")
  tokenUsage     Json         @default("{}") @map("token_usage")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@map("messages")
}

model ToolExecution {
  id           String              @id @default(uuid()) @db.Uuid
  conversationId String            @map("conversation_id") @db.Uuid
  toolName     String              @map("tool_name")
  input        Json                @default("{}")
  output       Json                @default("{}")
  status       ToolExecutionStatus
  startedAt    DateTime            @map("started_at")
  completedAt  DateTime?           @map("completed_at")
  durationMs   Int?                @map("duration_ms")
  error        String?
  createdAt    DateTime            @default(now()) @map("created_at")
  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([toolName])
  @@index([status])
  @@index([createdAt])
  @@map("tool_executions")
}

model Memory {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  category       String
  importance     Float
  content        String
  embeddingId    String?      @map("embedding_id")
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  accesses       MemoryAccess[]

  @@index([organizationId])
  @@index([userId])
  @@index([conversationId])
  @@index([category])
  @@index([importance])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("memories")
}

model MemoryAccess {
  id             String       @id @default(uuid()) @db.Uuid
  memoryId       String       @map("memory_id") @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  accessedAt     DateTime     @default(now()) @map("accessed_at")
  memory         Memory       @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@index([conversationId])
  @@index([accessedAt])
  @@map("memory_accesses")
}

model Agent {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  name           String
  description    String
  systemPrompt   String     @map("system_prompt")
  provider       String
  model          String
  configuration  Json       @default("{}")
  enabled        Boolean    @default(true)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs           AgentRun[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([enabled])
  @@index([deletedAt])
  @@map("agents")
}

model AgentRun {
  id             String         @id @default(uuid()) @db.Uuid
  agentId        String         @map("agent_id") @db.Uuid
  conversationId String         @map("conversation_id") @db.Uuid
  status         AgentRunStatus
  input          Json           @default("{}")
  output         Json           @default("{}")
  startedAt      DateTime       @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  durationMs     Int?           @map("duration_ms")
  tokenUsage     Json           @default("{}") @map("token_usage")
  error          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  agent          Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
  @@map("agent_runs")
}

model VerificationToken {
  id        String                @id @default(uuid()) @db.Uuid
  userId    String                @map("user_id") @db.Uuid
  tokenHash String                @map("token_hash")
  type      VerificationTokenType
  expiresAt DateTime              @map("expires_at")
  usedAt    DateTime?             @map("used_at")
  createdAt DateTime              @default(now()) @map("created_at")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([type])
  @@map("verification_tokens")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  requestId      String   @map("request_id")
  action         String
  resource       String
  resourceId     String?  @map("resource_id") @db.Uuid
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@index([requestId])
  @@map("audit_logs")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  key             String           @unique
  name            String
  description     String?
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  memberships     Membership[]
  rolePermissions RolePermission[]

  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  key             String           @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  roleId         String           @map("role_id") @db.Uuid
  joinedAt       DateTime         @default(now()) @map("joined_at")
  status         MembershipStatus @default(ACTIVE)
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
  role           Role             @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@map("memberships")
}

model SalesCompany {
  id            String             @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  name          String
  domain        String?
  website       String?
  industry      String?
  status        SalesCompanyStatus @default(PROSPECT)
  notes         String?
  metadata      Json               @default("{}")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")
  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts      SalesContact[]
  leads         SalesLead[]
  opportunities SalesOpportunity[]
  activities    SalesActivity[]

  @@index([organizationId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("sales_companies")
}

model SalesContact {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  companyId      String?       @map("company_id") @db.Uuid
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  email          String?
  phone          String?
  jobTitle       String?       @map("job_title")
  notes          String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company        SalesCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads          SalesLead[]
  opportunities  SalesOpportunity[]
  activities     SalesActivity[]

  @@index([organizationId])
  @@index([companyId])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("sales_contacts")
}

model SalesLead {
  id                   String          @id @default(uuid()) @db.Uuid
  organizationId       String          @map("organization_id") @db.Uuid
  companyId            String?         @map("company_id") @db.Uuid
  contactId            String?         @map("contact_id") @db.Uuid
  title                String
  source               String?
  status               SalesLeadStatus @default(NEW)
  qualificationScore   Int?            @map("qualification_score")
  qualificationSummary String?         @map("qualification_summary")
  notes                String?
  metadata             Json            @default("{}")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  deletedAt            DateTime?       @map("deleted_at")
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company              SalesCompany?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact              SalesContact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunities        SalesOpportunity[]
  activities           SalesActivity[]

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("sales_leads")
}

model SalesOpportunity {
  id              String                @id @default(uuid()) @db.Uuid
  organizationId  String                @map("organization_id") @db.Uuid
  companyId       String?               @map("company_id") @db.Uuid
  contactId       String?               @map("contact_id") @db.Uuid
  leadId          String?               @map("lead_id") @db.Uuid
  title           String
  stage           SalesOpportunityStage @default(DISCOVERY)
  amount          Float?
  currency        String                @default("USD")
  probability     Int                   @default(0)
  expectedCloseAt DateTime?             @map("expected_close_at")
  insights        String?
  nextBestAction  String?               @map("next_best_action")
  notes           String?
  metadata        Json                  @default("{}")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  deletedAt       DateTime?             @map("deleted_at")
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company         SalesCompany?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact         SalesContact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead            SalesLead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  activities      SalesActivity[]

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([stage])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("sales_opportunities")
}

model SalesActivity {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  companyId        String?           @map("company_id") @db.Uuid
  contactId        String?           @map("contact_id") @db.Uuid
  leadId           String?           @map("lead_id") @db.Uuid
  opportunityId    String?           @map("opportunity_id") @db.Uuid
  type             SalesActivityType
  subject          String
  description      String?
  occurredAt       DateTime?         @map("occurred_at")
  dueAt            DateTime?         @map("due_at")
  completed        Boolean           @default(false)
  meetingSummary   String?           @map("meeting_summary")
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company          SalesCompany?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact          SalesContact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead             SalesLead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  opportunity      SalesOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([type])
  @@index([completed])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("sales_activities")
}
