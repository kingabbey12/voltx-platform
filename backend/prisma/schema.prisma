enum KnowledgeSourceType {
  CRM_CONTACT
  CRM_COMPANY
  CRM_OPPORTUNITY
  CRM_ACTIVITY
  NOTE
  DOCUMENT
  EMAIL
  CALENDAR
  TASK
  MEETING
  UPLOADED_FILE
  AI_MEMORY
  MESSAGE
  ISSUE
  OTHER
}

enum KnowledgeSourceStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum KnowledgeDocumentStatus {
  PENDING
  INDEXING
  INDEXED
  FAILED
}

enum KnowledgeEntityType {
  PERSON
  COMPANY
  DEAL
  PROJECT
  TASK
  MEETING
  DOCUMENT
  EMAIL
  FILE
  NOTE
  AGENT
  WORKFLOW
  MEMORY
}

enum KnowledgeRelationshipType {
  OWNS
  WORKS_AT
  ASSOCIATED_WITH
  PARTICIPATED_IN
  ASSIGNED_TO
  MENTIONS
  ATTACHED_TO
  RELATED_TO
  CREATED_BY
}

/// A configured knowledge source: one CRM record type, file-upload bucket,
/// or other feed that documents are ingested from. Reindex/pause/health
/// operate at this granularity.
model KnowledgeSource {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  type           KnowledgeSourceType
  name           String
  description    String?
  config         Json                  @default("{}")
  status         KnowledgeSourceStatus @default(ACTIVE)
  lastIndexedAt  DateTime?             @map("last_indexed_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  deletedAt      DateTime?             @map("deleted_at")
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents      KnowledgeDocument[]

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
  @@map("knowledge_sources")
}

/// One ingestible unit of content (a CRM record snapshot, an uploaded file,
/// a note) belonging to a KnowledgeSource. Holds extracted raw text before
/// chunking; externalId lets re-ingestion of the same upstream record
/// update rather than duplicate.
model KnowledgeDocument {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  sourceId       String                  @map("source_id") @db.Uuid
  externalId     String?                 @map("external_id")
  title          String
  contentType    String                  @map("content_type")
  rawText        String?                 @map("raw_text")
  metadata       Json                    @default("{}")
  status         KnowledgeDocumentStatus @default(PENDING)
  indexedAt      DateTime?               @map("indexed_at")
  error          String?
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  deletedAt      DateTime?               @map("deleted_at")
  source         KnowledgeSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunks         KnowledgeChunk[]

  @@index([organizationId])
  @@index([sourceId])
  @@index([externalId])
  @@index([status])
  @@index([deletedAt])
  @@map("knowledge_documents")
}

/// A chunk of a document's extracted text plus its embedding vector — the
/// unit actually searched. The `embedding` column is `Unsupported` because
/// Prisma has no native pgvector type: all reads/writes to it go through
/// raw SQL in KnowledgeChunkRepository, and its migration is hand-written
/// (extension + column + ivfflat index + generated tsvector + GIN index).
model KnowledgeChunk {
  id             String                       @id @default(uuid()) @db.Uuid
  organizationId String                       @map("organization_id") @db.Uuid
  documentId     String                       @map("document_id") @db.Uuid
  chunkIndex     Int                          @map("chunk_index")
  content        String
  tokenCount     Int                          @map("token_count")
  embedding      Unsupported("vector(1536)")?
  /// Generated column (to_tsvector(content)), maintained entirely in the
  /// migration SQL — declared here only so Prisma doesn't propose dropping
  /// it on a future `migrate dev` diff.
  contentTsv     Unsupported("tsvector")?     @map("content_tsv")
  metadata       Json                         @default("{}")
  createdAt      DateTime                     @default(now()) @map("created_at")
  deletedAt      DateTime?                    @map("deleted_at")
  document       KnowledgeDocument            @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([documentId])
  @@index([deletedAt])
  @@map("knowledge_chunks")
}

/// A node in the knowledge graph — a person, company, deal, document, etc.
/// externalId links back to the originating CRM/document record so graph
/// nodes and knowledge documents can be cross-referenced without
/// duplicating data.
model KnowledgeEntity {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  type           KnowledgeEntityType
  externalId     String?                 @map("external_id")
  label          String
  metadata       Json                    @default("{}")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  deletedAt      DateTime?               @map("deleted_at")
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  outgoing       KnowledgeRelationship[] @relation("FromEntity")
  incoming       KnowledgeRelationship[] @relation("ToEntity")

  @@index([organizationId])
  @@index([type])
  @@index([externalId])
  @@index([deletedAt])
  @@map("knowledge_entities")
}

/// A directed, typed edge between two KnowledgeEntity nodes — what graph
/// traversal walks.
model KnowledgeRelationship {
  id             String                    @id @default(uuid()) @db.Uuid
  organizationId String                    @map("organization_id") @db.Uuid
  fromEntityId   String                    @map("from_entity_id") @db.Uuid
  toEntityId     String                    @map("to_entity_id") @db.Uuid
  type           KnowledgeRelationshipType
  metadata       Json                      @default("{}")
  createdAt      DateTime                  @default(now()) @map("created_at")
  fromEntity     KnowledgeEntity           @relation("FromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity       KnowledgeEntity           @relation("ToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([type])
  @@map("knowledge_relationships")
}

/// Retrieval observability: one row per knowledge search, feeding the
/// admin statistics/health endpoints (latency, hit rate, cache hit,
/// confidence, citation quality).
model KnowledgeSearchLog {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  query             String
  resultCount       Int      @map("result_count")
  citedResultCount  Int      @map("cited_result_count")
  topConfidence     Float?   @map("top_confidence")
  averageConfidence Float?   @map("average_confidence")
  latencyMs         Int      @map("latency_ms")
  cacheHit          Boolean  @default(false) @map("cache_hit")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([createdAt])
  @@map("knowledge_search_logs")
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkflowStepType {
  AGENT
  TOOL
  API
  WEBHOOK
  NOTIFICATION
  APPROVAL
  DELAY
  INTEGRATION
  /// Iterates an array from context/input, running its nested steps once
  /// per item. Explicit parallel-branch fan-out (independent of
  /// iteration) is already implicit via the DAG's `dependsOn` — this type
  /// exists for "repeat these steps for each X", not for concurrency.
  LOOP
  /// Multi-branch on a resolved value — each branch names the stepId to
  /// continue from, exactly one branch's target runs.
  SWITCH
}

enum WorkflowTriggerType {
  MANUAL
  IMMEDIATE
  DELAYED
  CRON
  EVENT
  API
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  PAUSED
  WAITING_APPROVAL
  SUCCEEDED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum WorkflowStepRunStatus {
  PENDING
  RUNNING
  WAITING_APPROVAL
  SUCCEEDED
  FAILED
  SKIPPED
  CANCELLED
  RETRYING
}

enum WorkflowApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum WorkflowLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

/// A named, versioned business process. The Workflow row itself is a
/// stable identity + status (DRAFT/PUBLISHED/ARCHIVED); the actual
/// executable DAG lives in immutable WorkflowVersion rows so a running
/// WorkflowRun always points at the exact definition it started with,
/// even if the workflow is edited or republished mid-flight.
model Workflow {
  id               String             @id @default(uuid()) @db.Uuid
  organizationId   String             @map("organization_id") @db.Uuid
  name             String
  description      String?
  status           WorkflowStatus     @default(DRAFT)
  publishedVersion Int?               @map("published_version")
  createdBy        String             @map("created_by") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions         WorkflowVersion[]
  runs             WorkflowRun[]
  schedules        WorkflowSchedule[]
  webhooks         WorkflowWebhook[]
  variables        WorkflowVariable[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([status])
  @@index([deletedAt])
  @@map("workflows")
}

/// One immutable snapshot of a workflow's step DAG. `definition` is the
/// validated JSON graph (steps, dependsOn, conditions, retry/timeout
/// policy) produced by WorkflowDefinitionValidatorService.
model WorkflowVersion {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  workflowId     String        @map("workflow_id") @db.Uuid
  version        Int
  definition     Json
  createdBy      String        @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  workflow       Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  runs           WorkflowRun[]

  @@unique([workflowId, version])
  @@index([organizationId])
  @@index([workflowId])
  @@map("workflow_versions")
}

/// A configured trigger for a workflow (cron, delayed, event-triggered).
/// MANUAL/IMMEDIATE/API triggers don't need a persisted schedule row —
/// they execute a run directly — so this table only holds triggers that
/// need to fire on their own later.
model WorkflowSchedule {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  workflowId     String              @map("workflow_id") @db.Uuid
  triggerType    WorkflowTriggerType @map("trigger_type")
  cronExpression String?             @map("cron_expression")
  delayMs        Int?                @map("delay_ms")
  eventName      String?             @map("event_name")
  input          Json                @default("{}")
  enabled        Boolean             @default(true)
  nextRunAt      DateTime?           @map("next_run_at")
  lastRunAt      DateTime?           @map("last_run_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  workflow       Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([workflowId])
  @@index([triggerType])
  @@index([enabled])
  @@index([nextRunAt])
  @@map("workflow_schedules")
}

/// One execution of a workflow version. `version` is an optimistic-
/// concurrency counter (incremented on every state transition) so
/// concurrent pause/resume/cancel/step-completion writes can detect and
/// reject a stale update instead of silently clobbering it. `context`
/// accumulates every completed step's output keyed by stepId, which is
/// how later steps and conditions reference earlier results.
model WorkflowRun {
  id                String                 @id @default(uuid()) @db.Uuid
  organizationId    String                 @map("organization_id") @db.Uuid
  workflowId        String                 @map("workflow_id") @db.Uuid
  workflowVersionId String                 @map("workflow_version_id") @db.Uuid
  conversationId    String                 @map("conversation_id") @db.Uuid
  status            WorkflowRunStatus      @default(PENDING)
  triggerType       WorkflowTriggerType    @map("trigger_type")
  input             Json                   @default("{}")
  context           Json                   @default("{}")
  output            Json                   @default("{}")
  currentStepId     String?                @map("current_step_id")
  idempotencyKey    String?                @map("idempotency_key")
  triggeredBy       String?                @map("triggered_by") @db.Uuid
  error             String?
  version           Int                    @default(0)
  startedAt         DateTime?              @map("started_at")
  completedAt       DateTime?              @map("completed_at")
  durationMs        Int?                   @map("duration_ms")
  queuedAt          DateTime               @default(now()) @map("queued_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  workflow          Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion   WorkflowVersion        @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  conversation      Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  stepRuns          WorkflowStepRun[]
  logs              WorkflowExecutionLog[]
  checkpoints       WorkflowCheckpoint[]
  approvals         WorkflowApproval[]
  deadLetters       WorkflowDeadLetter[]

  @@unique([workflowId, idempotencyKey])
  @@index([organizationId])
  @@index([workflowId])
  @@index([workflowVersionId])
  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
  @@map("workflow_runs")
}

/// One step's execution within a run. `attempt` tracks the current retry
/// count; individual retry attempts are additionally logged to
/// WorkflowRetryAttempt for full history.
model WorkflowStepRun {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  workflowRunId  String                 @map("workflow_run_id") @db.Uuid
  stepId         String                 @map("step_id")
  type           WorkflowStepType
  status         WorkflowStepRunStatus  @default(PENDING)
  input          Json                   @default("{}")
  output         Json                   @default("{}")
  attempt        Int                    @default(0)
  error          String?
  startedAt      DateTime?              @map("started_at")
  completedAt    DateTime?              @map("completed_at")
  durationMs     Int?                   @map("duration_ms")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  workflowRun    WorkflowRun            @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  retryAttempts  WorkflowRetryAttempt[]
  approvals      WorkflowApproval[]

  @@unique([workflowRunId, stepId])
  @@index([organizationId])
  @@index([workflowRunId])
  @@index([status])
  @@map("workflow_step_runs")
}

/// Full retry history for a step run — one row per failed attempt, kept
/// even after the step eventually succeeds, distinct from
/// WorkflowStepRun.attempt (the live counter) so past failures remain
/// inspectable.
model WorkflowRetryAttempt {
  id            String          @id @default(uuid()) @db.Uuid
  stepRunId     String          @map("step_run_id") @db.Uuid
  attemptNumber Int             @map("attempt_number")
  error         String
  delayMs       Int             @map("delay_ms")
  occurredAt    DateTime        @default(now()) @map("occurred_at")
  stepRun       WorkflowStepRun @relation(fields: [stepRunId], references: [id], onDelete: Cascade)

  @@index([stepRunId])
  @@map("workflow_retry_attempts")
}

/// Structured execution log / audit trail for a run — every lifecycle
/// event (WorkflowStarted, StepCompleted, etc.) is persisted here in
/// addition to being streamed live, so a run's full history survives
/// after the SSE connection is long gone.
model WorkflowExecutionLog {
  id            String           @id @default(uuid()) @db.Uuid
  workflowRunId String           @map("workflow_run_id") @db.Uuid
  stepRunId     String?          @map("step_run_id") @db.Uuid
  level         WorkflowLogLevel @default(INFO)
  event         String
  message       String
  metadata      Json             @default("{}")
  createdAt     DateTime         @default(now()) @map("created_at")
  workflowRun   WorkflowRun      @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
  @@index([stepRunId])
  @@index([createdAt])
  @@map("workflow_execution_logs")
}

/// A resumable snapshot of run state taken after each step completes —
/// what pause/resume and crash-recovery replay from, rather than
/// re-deriving progress from the step-run rows on every resume.
model WorkflowCheckpoint {
  id            String      @id @default(uuid()) @db.Uuid
  workflowRunId String      @map("workflow_run_id") @db.Uuid
  stepId        String      @map("step_id")
  state         Json
  createdAt     DateTime    @default(now()) @map("created_at")
  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
  @@index([createdAt])
  @@map("workflow_checkpoints")
}

/// A pending/decided human approval gate for an APPROVAL-type step.
model WorkflowApproval {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  workflowRunId  String                 @map("workflow_run_id") @db.Uuid
  stepRunId      String                 @map("step_run_id") @db.Uuid
  status         WorkflowApprovalStatus @default(PENDING)
  approverUserId String?                @map("approver_user_id") @db.Uuid
  comment        String?
  expiresAt      DateTime?              @map("expires_at")
  decidedAt      DateTime?              @map("decided_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  workflowRun    WorkflowRun            @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  stepRun        WorkflowStepRun        @relation(fields: [stepRunId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([workflowRunId])
  @@index([stepRunId])
  @@index([status])
  @@map("workflow_approvals")
}

/// A step whose retries were exhausted (or which failed unrecoverably)
/// lands here for manual inspection/replay instead of silently
/// disappearing — the workflow engine's dead letter queue.
model WorkflowDeadLetter {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  workflowRunId  String      @map("workflow_run_id") @db.Uuid
  stepId         String      @map("step_id")
  reason         String
  payload        Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")
  workflowRun    WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([workflowRunId])
  @@index([createdAt])
  @@map("workflow_dead_letters")
}

/// v1.9.1 hardening — generic dead-letter record for any BullMQ queue
/// (comms AI processing, attachment processing, AI agent-task resume)
/// once a job exhausts its configured retry attempts. organizationId is
/// best-effort (resolved from the job's payload where possible) and
/// nullable since not every job's payload cheaply resolves to one.
model BackgroundJobFailure {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  queueName      String   @map("queue_name")
  jobName        String   @map("job_name")
  jobId          String?  @map("job_id")
  payload        Json     @default("{}")
  failureReason  String   @map("failure_reason")
  attemptsMade   Int      @map("attempts_made")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([queueName])
  @@index([createdAt])
  @@map("background_job_failures")
}

// ─────────────────────────────────────────────────────────────
// Workflow Automation Platform (v2.0)
// ─────────────────────────────────────────────────────────────

enum WorkflowVariableType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

/// A reusable workflow blueprint. System templates (`isSystem: true`,
/// `organizationId: null`) ship with the platform and are visible to
/// every org; a custom template is a per-org copy an admin saved from an
/// existing workflow. `definition` is the same validated
/// WorkflowDefinition JSON shape a WorkflowVersion holds — instantiating
/// a template just creates a real Workflow + first WorkflowVersion from
/// it, it isn't a parallel execution path.
model WorkflowTemplate {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  key            String        @unique
  name           String
  description    String?
  category       String
  definition     Json
  isSystem       Boolean       @default(false) @map("is_system")
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([category])
  @@index([isSystem])
  @@index([deletedAt])
  @@map("workflow_templates")
}

/// An encrypted, org-scoped named value workflow steps can reference
/// (e.g. a third-party API key) without embedding it in a workflow
/// definition. `encryptedValue` uses the same EncryptionService every
/// other credential in this codebase uses — the value is never returned
/// by any read endpoint, only key/metadata are.
model WorkflowSecret {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  key            String
  encryptedValue String       @map("encrypted_value") @db.Text
  description    String?
  createdBy      String       @map("created_by") @db.Uuid
  lastRotatedAt  DateTime?    @map("last_rotated_at")
  lastUsedAt     DateTime?    @map("last_used_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("workflow_secrets")
}

/// A registered inbound webhook that starts a workflow run — mirrors
/// IntegrationWebhookEndpoint's pattern exactly (`token` is the
/// unguessable path segment, `encryptedSecret` verifies the caller's
/// HMAC signature, never authorizes the URL by itself).
model WorkflowWebhook {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  workflowId      String       @map("workflow_id") @db.Uuid
  token           String       @unique
  encryptedSecret String       @map("encrypted_secret") @db.Text
  enabled         Boolean      @default(true)
  lastTriggeredAt DateTime?    @map("last_triggered_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow        Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([workflowId])
  @@map("workflow_webhooks")
}

/// A named value steps can reference via `{{variables.<key>}}` in
/// addition to `{{input.x}}`/`{{context.x}}`. `workflowId: null` is an
/// org-level shared variable (visible to every workflow in the org);
/// non-null scopes it to one workflow.
model WorkflowVariable {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  workflowId     String?              @map("workflow_id") @db.Uuid
  key            String
  type           WorkflowVariableType @default(STRING)
  defaultValue   Json                 @default("null") @map("default_value")
  description    String?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow       Workflow?            @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([organizationId, workflowId, key])
  @@index([organizationId])
  @@index([workflowId])
  @@map("workflow_variables")
}

// ─────────────────────────────────────────────────────────────
// Enterprise Integration Platform (VT-025)
// ─────────────────────────────────────────────────────────────

enum IntegrationProviderKey {
  GOOGLE_GMAIL
  GOOGLE_CALENDAR
  GOOGLE_DRIVE
  MICROSOFT_OUTLOOK
  MICROSOFT_CALENDAR
  MICROSOFT_ONEDRIVE
  SLACK
  MICROSOFT_TEAMS
  GITHUB
  STRIPE
  WEBHOOK
  REST_API
}

enum IntegrationAuthType {
  OAUTH2
  API_KEY
  WEBHOOK_SECRET
  NONE
}

enum IntegrationConnectionStatus {
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
  REVOKED
  TOKEN_EXPIRED
}

enum IntegrationHealthStatus {
  HEALTHY
  DEGRADED
  UNHEALTHY
  UNKNOWN
}

enum IntegrationSyncTrigger {
  MANUAL
  POLL
  WEBHOOK
  SCHEDULED
}

enum IntegrationSyncStatus {
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum IntegrationEventType {
  EMAIL_RECEIVED
  MEETING_CREATED
  FILE_UPLOADED
  PAYMENT_RECEIVED
  SLACK_MESSAGE
  TEAMS_MESSAGE
  GITHUB_ISSUE
  WEBHOOK_RECEIVED
  API_EVENT
  CONNECTION_CONNECTED
  CONNECTION_ERROR
  TOKEN_REFRESHED
}

/// One connected external account (a Gmail inbox, a Slack workspace, a
/// Stripe account, ...). `version` is bumped on every update for
/// optimistic concurrency (same convention as WorkflowRun) and doubles as
/// the "Connection Versioning" enterprise feature; full change history
/// lives in AuditLog rather than a separate version table, since audit
/// logging already captures who-changed-what-when generically.
model IntegrationConnection {
  id                String                       @id @default(uuid()) @db.Uuid
  organizationId    String                       @map("organization_id") @db.Uuid
  provider          IntegrationProviderKey
  displayName       String                       @map("display_name")
  authType          IntegrationAuthType          @map("auth_type")
  status            IntegrationConnectionStatus  @default(PENDING)
  externalAccountId String?                      @map("external_account_id")
  config            Json                         @default("{}")
  version           Int                          @default(0)
  lastHealthCheckAt DateTime?                    @map("last_health_check_at")
  lastHealthStatus  IntegrationHealthStatus      @default(UNKNOWN) @map("last_health_status")
  lastSyncAt        DateTime?                    @map("last_sync_at")
  lastError         String?                      @map("last_error")
  createdBy         String                       @map("created_by") @db.Uuid
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")
  deletedAt         DateTime?                    @map("deleted_at")
  organization      Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  credential        IntegrationCredential?
  webhookEndpoints  IntegrationWebhookEndpoint[]
  events            IntegrationEvent[]
  syncRuns          IntegrationSyncRun[]
  apiUsageLogs      IntegrationApiUsageLog[]
  healthChecks      IntegrationHealthCheck[]

  @@unique([organizationId, provider, externalAccountId])
  @@index([organizationId])
  @@index([provider])
  @@index([status])
  @@index([deletedAt])
  @@map("integration_connections")
}

/// The decrypted-at-use secret material for a connection, kept in a
/// separate table from IntegrationConnection so listing/updating
/// connection metadata never touches encrypted payloads. One JSON blob
/// (access token, refresh token, api key, provider-specific extras) is
/// encrypted as a single unit by EncryptionService rather than
/// field-by-field — simpler, and `expiresAt` is kept OUTSIDE the
/// encrypted blob so token-refresh sweeps can query "expiring soon"
/// without decrypting every row.
model IntegrationCredential {
  id               String                @id @default(uuid()) @db.Uuid
  connectionId     String                @unique @map("connection_id") @db.Uuid
  organizationId   String                @map("organization_id") @db.Uuid
  encryptedPayload String                @map("encrypted_payload") @db.Text
  expiresAt        DateTime?             @map("expires_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  connection       IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
  @@map("integration_credentials")
}

/// A registered inbound webhook URL (`/api/v1/integrations/webhooks/:token`)
/// for a connection — `token` is the unguessable path segment, distinct
/// from `encryptedSecret` which is used to verify the provider's request
/// signature (HMAC etc.), never to authorize the URL itself.
model IntegrationWebhookEndpoint {
  id              String                 @id @default(uuid()) @db.Uuid
  connectionId    String                 @map("connection_id") @db.Uuid
  organizationId  String                 @map("organization_id") @db.Uuid
  provider        IntegrationProviderKey
  token           String                 @unique
  encryptedSecret String                 @map("encrypted_secret") @db.Text
  enabled         Boolean                @default(true)
  lastReceivedAt  DateTime?              @map("last_received_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  connection      IntegrationConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([organizationId])
  @@map("integration_webhook_endpoints")
}

/// One normalized fact observed via webhook or poll. `externalId` (the
/// provider's own event/message id) plus the unique constraint below is
/// what makes webhook/poll processing idempotent — replays of the same
/// upstream event are silently deduplicated at the DB layer rather than
/// with an application-level cache.
model IntegrationEvent {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  connectionId   String                @map("connection_id") @db.Uuid
  type           IntegrationEventType
  externalId     String?               @map("external_id")
  payload        Json                  @default("{}")
  processedAt    DateTime?             @map("processed_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  connection     IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalId])
  @@index([organizationId])
  @@index([connectionId])
  @@index([type])
  @@index([createdAt])
  @@map("integration_events")
}

/// History of poll/webhook-triggered sync jobs for a connection.
model IntegrationSyncRun {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  connectionId   String                 @map("connection_id") @db.Uuid
  trigger        IntegrationSyncTrigger
  status         IntegrationSyncStatus  @default(RUNNING)
  startedAt      DateTime               @default(now()) @map("started_at")
  completedAt    DateTime?              @map("completed_at")
  durationMs     Int?                   @map("duration_ms")
  itemsProcessed Int                    @default(0) @map("items_processed")
  itemsFailed    Int                    @default(0) @map("items_failed")
  error          String?
  createdAt      DateTime               @default(now()) @map("created_at")
  connection     IntegrationConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
  @@map("integration_sync_runs")
}

/// Per-call telemetry (status, duration, rate-limit headroom, retries) —
/// the basis for the "API Usage" / "Rate Limits" / "Retries" observability
/// requirements, mirroring AiUsageLog's role for the AI Gateway.
model IntegrationApiUsageLog {
  id                 String                @id @default(uuid()) @db.Uuid
  organizationId     String                @map("organization_id") @db.Uuid
  connectionId       String                @map("connection_id") @db.Uuid
  action             String
  statusCode         Int?                  @map("status_code")
  durationMs         Int                   @map("duration_ms")
  rateLimitRemaining Int?                  @map("rate_limit_remaining")
  retryCount         Int                   @default(0) @map("retry_count")
  error              String?
  createdAt          DateTime              @default(now()) @map("created_at")
  connection         IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([connectionId])
  @@index([createdAt])
  @@map("integration_api_usage_logs")
}

/// History of health checks for a connection (manual or scheduled).
model IntegrationHealthCheck {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  connectionId   String                  @map("connection_id") @db.Uuid
  status         IntegrationHealthStatus
  latencyMs      Int?                    @map("latency_ms")
  message        String?
  checkedAt      DateTime                @default(now()) @map("checked_at")
  connection     IntegrationConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([checkedAt])
  @@map("integration_health_checks")
}

// ============================================================================
// Unified Communications Platform (Phase 6) — one inbox across email,
// WhatsApp, SMS, voice, Slack, Teams. `Conversation`/`Message` above are the
// AI chat models; these are prefixed `Comms` to avoid collision. Follows the
// same tenant/soft-delete/timestamp conventions as the Integrations models
// above. Secondary/dependent models (credential, participant, message,
// attachment, call, recording, transcription, event, identity, reaction,
// summary) carry organizationId as a plain indexed column without a formal
// Organization relation, matching IntegrationApiUsageLog/
// IntegrationHealthCheck — only directly organization-owned entities
// (ChannelConnection, Conversation, ConversationLabel) get the full relation.
// ============================================================================

enum CommsChannel {
  GMAIL
  OUTLOOK
  WHATSAPP
  TWILIO_VOICE
  TWILIO_SMS
  SLACK
  TEAMS
}

enum CommsChannelConnectionStatus {
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
  REVOKED
  TOKEN_EXPIRED
}

enum CommsConversationStatus {
  OPEN
  PINNED
  ARCHIVED
}

enum CommsConversationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CommsMessageDirection {
  INBOUND
  OUTBOUND
}

enum CommsMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum CommsParticipantRole {
  CUSTOMER
  AGENT
}

enum CommsCallDirection {
  INBOUND
  OUTBOUND
}

enum CommsCallStatus {
  RINGING
  IN_PROGRESS
  COMPLETED
  MISSED
  FAILED
  VOICEMAIL
}

enum CommsEventType {
  DELIVERED
  READ
  TYPING
  REACTION_ADDED
  REACTION_REMOVED
}

/// A connected messaging channel (Gmail inbox, Slack workspace, etc).
/// Mirrors IntegrationConnection deliberately — same OAuth/health/sync
/// shape — but kept as a separate table since a channel connection means
/// something different operationally (it owns conversations/messages, not
/// tool-callable actions) even though the underlying OAuth mechanics reuse
/// OAuthService/EncryptionService verbatim.
model CommsChannelConnection {
  id                String                       @id @default(uuid()) @db.Uuid
  organizationId    String                       @map("organization_id") @db.Uuid
  channel           CommsChannel
  displayName       String                       @map("display_name")
  status            CommsChannelConnectionStatus @default(PENDING)
  externalAccountId String?                      @map("external_account_id")
  config            Json                         @default("{}")
  lastHealthCheckAt DateTime?                    @map("last_health_check_at")
  lastHealthStatus  IntegrationHealthStatus      @default(UNKNOWN) @map("last_health_status")
  lastSyncAt        DateTime?                    @map("last_sync_at")
  lastError         String?                      @map("last_error")
  createdBy         String                       @map("created_by") @db.Uuid
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")
  deletedAt         DateTime?                    @map("deleted_at")
  organization      Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  credential        CommsChannelCredential?
  conversations     CommsConversation[]
  calls             CommsCall[]

  @@unique([organizationId, channel, externalAccountId])
  @@index([organizationId])
  @@index([channel])
  @@index([status])
  @@index([deletedAt])
  @@map("comms_channel_connections")
}

/// Encrypted credential for a channel connection, split from the parent
/// table for the same reason IntegrationCredential is split from
/// IntegrationConnection — listing/updating connection metadata never
/// touches encrypted payloads.
model CommsChannelCredential {
  id               String                 @id @default(uuid()) @db.Uuid
  connectionId     String                 @unique @map("connection_id") @db.Uuid
  organizationId   String                 @map("organization_id") @db.Uuid
  encryptedPayload String                 @map("encrypted_payload") @db.Text
  expiresAt        DateTime?              @map("expires_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  connection       CommsChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
  @@map("comms_channel_credentials")
}

/// One thread, potentially spanning a single channel's history with one
/// customer. `externalThreadId` carries the provider's own thread/DM id
/// (Gmail thread id, Slack channel/DM id) for inbound-message correlation.
model CommsConversation {
  id               String                       @id @default(uuid()) @db.Uuid
  organizationId   String                       @map("organization_id") @db.Uuid
  connectionId     String                       @map("connection_id") @db.Uuid
  contactId        String?                      @map("contact_id") @db.Uuid
  assigneeId       String?                      @map("assignee_id") @db.Uuid
  channel          CommsChannel
  subject          String?
  status           CommsConversationStatus      @default(OPEN)
  priority         CommsConversationPriority    @default(NORMAL)
  unread           Boolean                      @default(true)
  externalThreadId String?                      @map("external_thread_id")
  lastMessageAt    DateTime?                    @map("last_message_at")
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")
  deletedAt        DateTime?                    @map("deleted_at")
  organization     Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection       CommsChannelConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  contact          SalesContact?                @relation(fields: [contactId], references: [id], onDelete: SetNull)
  participants     CommsParticipant[]
  messages         CommsMessage[]
  notes            CommsNote[]
  calls            CommsCall[]
  events           CommunicationEvent[]
  labelLinks       CommsConversationLabelLink[]
  summaries        AIConversationSummary[]

  @@index([organizationId])
  @@index([connectionId])
  @@index([contactId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([unread])
  @@index([lastMessageAt])
  @@index([deletedAt])
  @@map("comms_conversations")
}

/// Who's in a conversation — a CRM contact (customer side) or an internal
/// user (agent side), or neither yet if the external address hasn't been
/// resolved to a contact.
model CommsParticipant {
  id              String               @id @default(uuid()) @db.Uuid
  organizationId  String               @map("organization_id") @db.Uuid
  conversationId  String               @map("conversation_id") @db.Uuid
  contactId       String?              @map("contact_id") @db.Uuid
  userId          String?              @map("user_id") @db.Uuid
  role            CommsParticipantRole
  externalAddress String?              @map("external_address")
  displayName     String?              @map("display_name")
  createdAt       DateTime             @default(now()) @map("created_at")
  conversation    CommsConversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact         SalesContact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([conversationId])
  @@index([contactId])
  @@map("comms_participants")
}

/// One message in a conversation. Immutable once created (no soft delete) —
/// status transitions (queued -> sent -> delivered -> read -> failed) are
/// tracked via the timestamp columns rather than mutating history.
model CommsMessage {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  conversationId String                @map("conversation_id") @db.Uuid
  senderId       String?               @map("sender_id") @db.Uuid
  direction      CommsMessageDirection
  channel        CommsChannel
  status         CommsMessageStatus    @default(QUEUED)
  body           String                @db.Text
  externalId     String?               @map("external_id")
  metadata       Json                  @default("{}")
  sentAt         DateTime?             @map("sent_at")
  deliveredAt    DateTime?             @map("delivered_at")
  readAt         DateTime?             @map("read_at")
  failedReason   String?               @map("failed_reason")
  createdAt      DateTime              @default(now()) @map("created_at")
  conversation   CommsConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reactions      MessageReaction[]

  @@index([organizationId])
  @@index([conversationId])
  @@index([direction])
  @@index([status])
  @@index([externalId])
  @@index([createdAt])
  @@map("comms_messages")
}

/// Internal, agent-only commentary on a conversation — never sent through
/// the channel, never visible to the customer. Kept as its own model
/// rather than a flag on CommsMessage so the message table stays a pure,
/// append-only record of real channel traffic (send/receive), matching
/// its existing "immutable once created" doc comment above.
model CommsNote {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  conversationId String            @map("conversation_id") @db.Uuid
  authorId       String            @map("author_id") @db.Uuid
  body           String            @db.Text
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  conversation   CommsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conversationId])
  @@map("comms_notes")
}

model CommsCall {
  id              String                 @id @default(uuid()) @db.Uuid
  organizationId  String                 @map("organization_id") @db.Uuid
  conversationId  String?                @map("conversation_id") @db.Uuid
  connectionId    String                 @map("connection_id") @db.Uuid
  direction       CommsCallDirection
  status          CommsCallStatus
  fromNumber      String                 @map("from_number")
  toNumber        String                 @map("to_number")
  durationSeconds Int?                   @map("duration_seconds")
  externalCallId  String?                @map("external_call_id")
  notes           String?
  startedAt       DateTime?              @map("started_at")
  endedAt         DateTime?              @map("ended_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  conversation    CommsConversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  connection      CommsChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  recording       CommsCallRecording?
  transcription   CommsTranscription?

  @@index([organizationId])
  @@index([conversationId])
  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
  @@map("comms_calls")
}

model CommsCallRecording {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  callId          String    @unique @map("call_id") @db.Uuid
  storageUrl      String    @map("storage_url")
  durationSeconds Int?      @map("duration_seconds")
  createdAt       DateTime  @default(now()) @map("created_at")
  call            CommsCall @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("comms_call_recordings")
}

model CommsTranscription {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  callId         String    @unique @map("call_id") @db.Uuid
  text           String    @db.Text
  language       String?
  createdAt      DateTime  @default(now()) @map("created_at")
  call           CommsCall @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("comms_transcriptions")
}

/// Append-only fact log for anything not worth its own table (delivered,
/// read, typing, reaction add/remove) — mirrors IntegrationEvent's role
/// for the integrations module.
model CommunicationEvent {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  conversationId String            @map("conversation_id") @db.Uuid
  messageId      String?           @map("message_id") @db.Uuid
  type           CommsEventType
  payload        Json              @default("{}")
  occurredAt     DateTime          @default(now()) @map("occurred_at")
  conversation   CommsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conversationId])
  @@index([type])
  @@index([occurredAt])
  @@map("communication_events")
}

/// Maps an external channel identifier (WhatsApp/Twilio phone number,
/// Slack user id) to a CRM contact, so inbound messages from a known
/// number/handle resolve to the right contact automatically. Created once
/// AI extraction (or manual linking) resolves who an address belongs to.
model CommsChannelIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  contactId       String       @map("contact_id") @db.Uuid
  channel         CommsChannel
  externalAddress String       @map("external_address")
  createdAt       DateTime     @default(now()) @map("created_at")
  contact         SalesContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([organizationId, channel, externalAddress])
  @@index([organizationId])
  @@index([contactId])
  @@map("comms_channel_identities")
}

model ConversationLabel {
  id             String                       @id @default(uuid()) @db.Uuid
  organizationId String                       @map("organization_id") @db.Uuid
  name           String
  color          String                       @default("#6366F1")
  createdAt      DateTime                     @default(now()) @map("created_at")
  organization   Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations  CommsConversationLabelLink[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("comms_conversation_labels")
}

model CommsConversationLabelLink {
  conversationId String            @map("conversation_id") @db.Uuid
  labelId        String            @map("label_id") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at")
  conversation   CommsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label          ConversationLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([conversationId, labelId])
  @@map("comms_conversation_label_links")
}

model MessageReaction {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  messageId      String       @map("message_id") @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  emoji          String
  externalUserId String?      @map("external_user_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  message        CommsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([messageId])
  @@map("comms_message_reactions")
}

/// AI-generated summary/sentiment/urgency/intent for a conversation,
/// versioned since it's regenerated as the conversation grows rather than
/// mutated in place — lets the UI show summary history if useful later.
model AIConversationSummary {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  conversationId String            @map("conversation_id") @db.Uuid
  version        Int               @default(1)
  summary        String            @db.Text
  sentiment      String?
  urgency        String?
  intent         String?
  createdAt      DateTime          @default(now()) @map("created_at")
  conversation   CommsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conversationId])
  @@map("ai_conversation_summaries")
}

enum NotificationCategory {
  MESSAGE
  CALL
  MEETING
  CRM
  WORKFLOW
  AI
  SECURITY
  BILLING
}

/// A single addressable, persisted notification for one user. Distinct
/// from CommunicationEvent (an append-only fact log about a conversation)
/// and from the workflow NOTIFICATION step (which sends an outbound
/// webhook/log line as an action) — this is the queryable, mark-readable
/// feed a user actually sees in the notification center.
model Notification {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  category       NotificationCategory
  title          String
  body           String?
  actionUrl      String?              @map("action_url")
  metadata       Json                 @default("{}")
  read           Boolean              @default(false)
  readAt         DateTime?            @map("read_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum AiSuggestionCategory {
  SALES
  SUPPORT
  OPERATIONS
  FINANCE
  GENERAL
}

/// A proactive, AI-generated suggestion for the AI Operator dashboard —
/// generated on-demand (cached per organization; see
/// AiSuggestionService.getOrGenerate) by the Executive Assistant agent
/// rather than fabricated client-side, and dismissible so the list
/// doesn't grow unbounded.
model AiSuggestion {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  category       AiSuggestionCategory @default(GENERAL)
  title          String
  description    String
  createdAt      DateTime             @default(now()) @map("created_at")
  dismissedAt    DateTime?            @map("dismissed_at")

  @@index([organizationId, dismissedAt])
  @@index([createdAt])
  @@map("ai_suggestions")
}

// ============================================================================
// Attachments — organization-scoped file storage shared by AI chat, CRM
// entities, and communications, with a swappable storage backend (local
// filesystem for dev, S3-compatible for prod — see
// src/modules/attachments/storage). AttachmentReference is deliberately
// polymorphic (referenceType + referenceId, no formal relation) since one
// attachment can be linked to a conversation, a CRM record, or an AI
// session — the same pattern IntegrationApiUsageLog/IntegrationHealthCheck
// use for cross-cutting rows that don't belong to one parent table.
// ============================================================================

enum AttachmentStatus {
  PENDING
  UPLOADING
  PROCESSING
  READY
  QUARANTINED
  FAILED
}

enum AttachmentReferenceType {
  AI_CONVERSATION
  AI_MESSAGE
  CRM_CONTACT
  CRM_COMPANY
  CRM_LEAD
  CRM_OPPORTUNITY
  CRM_ACTIVITY
  COMMS_MESSAGE
}

/// A single stored file. `storageKey` is opaque to callers — only the
/// configured StorageProvider knows how to resolve it into bytes.
/// `version` bumps on replace-in-place (rare); most edits create a new
/// Attachment row instead, with AttachmentVersion reserved for the
/// explicit "replace this exact file" flow.
model Attachment {
  id              String                @id @default(uuid()) @db.Uuid
  organizationId  String                @map("organization_id") @db.Uuid
  uploadedBy      String                @map("uploaded_by") @db.Uuid
  fileName        String                @map("file_name")
  mimeType        String                @map("mime_type")
  sizeBytes       Int                   @map("size_bytes")
  storageProvider String                @map("storage_provider")
  storageKey      String                @map("storage_key")
  checksumSha256  String?               @map("checksum_sha256")
  status          AttachmentStatus      @default(PENDING)
  scanResult      String?               @map("scan_result")
  thumbnailKey    String?               @map("thumbnail_key")
  width           Int?
  height          Int?
  extractedText   String?               @map("extracted_text") @db.Text
  metadata        Json                  @default("{}")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  deletedAt       DateTime?             @map("deleted_at")
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploader        User                  @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  versions        AttachmentVersion[]
  references      AttachmentReference[]

  @@index([organizationId])
  @@index([uploadedBy])
  @@index([status])
  @@index([deletedAt])
  @@index([organizationId, createdAt])
  @@map("attachments")
}

/// Append-only history of prior file content for an Attachment that was
/// explicitly replaced in place (not a new upload). createdBy tracks who
/// performed the replace; the current content always lives on Attachment
/// itself, never solely in the latest version row.
model AttachmentVersion {
  id             String     @id @default(uuid()) @db.Uuid
  attachmentId   String     @map("attachment_id") @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  versionNumber  Int        @map("version_number")
  storageKey     String     @map("storage_key")
  sizeBytes      Int        @map("size_bytes")
  checksumSha256 String?    @map("checksum_sha256")
  createdBy      String     @map("created_by") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at")
  attachment     Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([attachmentId, versionNumber])
  @@index([organizationId])
  @@map("attachment_versions")
}

/// Polymorphic link from an Attachment to whatever it's attached to.
model AttachmentReference {
  id             String                  @id @default(uuid()) @db.Uuid
  attachmentId   String                  @map("attachment_id") @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  referenceType  AttachmentReferenceType @map("reference_type")
  referenceId    String                  @map("reference_id") @db.Uuid
  createdAt      DateTime                @default(now()) @map("created_at")
  attachment     Attachment              @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([attachmentId, referenceType, referenceId])
  @@index([organizationId])
  @@index([referenceType, referenceId])
  @@map("attachment_references")
}

// =============================================================
// Billing & Revenue Platform (v2.1) — Stripe is the only payment
// provider. Plan/Feature/FeatureLimit/Coupon/Promotion are the
// platform's own catalog (org-less, shared); everything else is
// organization-scoped. BillingEvent is org-nullable because a
// webhook can arrive before Voltx resolves which org it belongs to.
// =============================================================

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
  PAUSED
}

enum SubscriptionChangeType {
  UPGRADE
  DOWNGRADE
  CANCEL
  RESUME
  TRIAL_START
  TRIAL_END
  SEAT_CHANGE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  PENDING
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethodType {
  CARD
  BANK
  OTHER
}

enum FeatureUnit {
  COUNT
  TOKENS
  BYTES
  MINUTES
}

enum CouponDuration {
  ONCE
  REPEATING
  FOREVER
}

enum TaxExemptStatus {
  NONE
  EXEMPT
  REVERSE
}

enum CheckoutSessionStatus {
  OPEN
  COMPLETE
  EXPIRED
}

/// Voltx's own pricing catalog — Free/Starter/Professional/Business/
/// Enterprise. Org-less by design (shared platform data, not tenant
/// data). Enterprise's price columns are null ("contact us"); its
/// FeatureLimit rows use a null `limit` (unlimited).
model Plan {
  id                   String         @id @default(uuid()) @db.Uuid
  key                  String         @unique
  name                 String
  description          String?
  stripeProductId      String?        @map("stripe_product_id")
  stripePriceIdMonthly String?        @map("stripe_price_id_monthly")
  stripePriceIdYearly  String?        @map("stripe_price_id_yearly")
  priceMonthlyUsd      Decimal?       @map("price_monthly_usd") @db.Decimal(12, 2)
  priceYearlyUsd       Decimal?       @map("price_yearly_usd") @db.Decimal(12, 2)
  isActive             Boolean        @default(true) @map("is_active")
  sortOrder            Int            @default(0) @map("sort_order")
  trialDays            Int            @default(14) @map("trial_days")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  featureLimits        FeatureLimit[]
  subscriptions        Subscription[]

  @@index([isActive])
  @@map("billing_plans")
}

/// One meterable/gateable dimension (ai_requests, workflow_executions,
/// whatsapp_messages, storage, ...). The `key` is what
/// UsageMeteringService/QuotaService key off of at runtime.
model Feature {
  id                String             @id @default(uuid()) @db.Uuid
  key               String             @unique
  name              String
  unit              FeatureUnit
  category          String
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  featureLimits     FeatureLimit[]
  subscriptionItems SubscriptionItem[]
  invoiceItems      InvoiceItem[]

  @@index([category])
  @@map("billing_features")
}

model FeatureLimit {
  id               String   @id @default(uuid()) @db.Uuid
  planId           String   @map("plan_id") @db.Uuid
  featureId        String   @map("feature_id") @db.Uuid
  /// null = unlimited (Enterprise). BigInt — byte-denominated limits
  /// (storage) exceed a 32-bit Int's range.
  limit            BigInt?
  softLimitPercent Int?     @map("soft_limit_percent")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  plan             Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature          Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@index([featureId])
  @@map("billing_feature_limits")
}

/// The organization's one Stripe Customer. Created once, at
/// registration (Phase 1, before any Stripe API call exists) — a real
/// row with `stripeCustomerId` genuinely null, not a fabricated
/// placeholder value in that column. Phase 2's StripeCustomerService
/// backfills it the first time it actually talks to Stripe.
model BillingAccount {
  id                     String                  @id @default(uuid()) @db.Uuid
  organizationId         String                  @unique @map("organization_id") @db.Uuid
  stripeCustomerId       String?                 @unique @map("stripe_customer_id")
  email                  String?
  defaultPaymentMethodId String?                 @map("default_payment_method_id") @db.Uuid
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  taxProfile             TaxProfile?
  subscriptions          Subscription[]
  invoices               Invoice[]
  paymentMethods         PaymentMethod[]
  checkoutSessions       CheckoutSession[]
  portalSessions         CustomerPortalSession[]

  @@map("billing_accounts")
}

/// One organization's subscription to a Plan. `stripeSubscriptionId` is
/// nullable — a brand-new trial subscription is a real local row before
/// any Stripe Subscription object exists (Stripe only enters the
/// picture once a payment method is attached / the trial converts).
model Subscription {
  id                   String               @id @default(uuid()) @db.Uuid
  organizationId       String               @map("organization_id") @db.Uuid
  billingAccountId     String               @map("billing_account_id") @db.Uuid
  planId               String               @map("plan_id") @db.Uuid
  stripeSubscriptionId String?              @unique @map("stripe_subscription_id")
  status               SubscriptionStatus   @default(TRIALING)
  seats                Int                  @default(1)
  currentPeriodStart   DateTime             @map("current_period_start")
  currentPeriodEnd     DateTime             @map("current_period_end")
  trialStart           DateTime?            @map("trial_start")
  trialEnd             DateTime?            @map("trial_end")
  cancelAtPeriodEnd    Boolean              @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?            @map("canceled_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingAccount       BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  plan                 Plan                 @relation(fields: [planId], references: [id])
  items                SubscriptionItem[]
  changes              SubscriptionChange[]
  seatAssignments      SeatAssignment[]
  discounts            Discount[]

  @@index([organizationId])
  @@index([billingAccountId])
  @@index([planId])
  @@index([status])
  @@map("billing_subscriptions")
}

model SubscriptionItem {
  id                       String       @id @default(uuid()) @db.Uuid
  subscriptionId           String       @map("subscription_id") @db.Uuid
  featureId                String?      @map("feature_id") @db.Uuid
  stripeSubscriptionItemId String?      @unique @map("stripe_subscription_item_id")
  stripePriceId            String?      @map("stripe_price_id")
  quantity                 Int?
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")
  subscription             Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  feature                  Feature?     @relation(fields: [featureId], references: [id])

  @@index([subscriptionId])
  @@map("billing_subscription_items")
}

/// Audit trail of every upgrade/downgrade/cancel/resume/trial
/// transition — separate from AuditLog (which is generic platform-wide
/// audit) because this one is billing-domain-shaped and cheap to query
/// for "show me this org's plan history."
model SubscriptionChange {
  id             String                 @id @default(uuid()) @db.Uuid
  subscriptionId String                 @map("subscription_id") @db.Uuid
  fromPlanId     String?                @map("from_plan_id") @db.Uuid
  toPlanId       String?                @map("to_plan_id") @db.Uuid
  changeType     SubscriptionChangeType @map("change_type")
  effectiveAt    DateTime               @map("effective_at")
  initiatedBy    String?                @map("initiated_by") @db.Uuid
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now()) @map("created_at")
  subscription   Subscription           @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([changeType])
  @@map("billing_subscription_changes")
}

/// Which active Membership consumes a paid seat. No DB-unique
/// constraint on membershipId (a released seat's row stays for
/// history, `releasedAt` marks it inactive) — "does this membership
/// currently hold a seat" is `releasedAt IS NULL`, enforced by
/// SeatAssignmentService, not the schema.
model SeatAssignment {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  subscriptionId String       @map("subscription_id") @db.Uuid
  membershipId   String       @map("membership_id") @db.Uuid
  assignedAt     DateTime     @default(now()) @map("assigned_at")
  releasedAt     DateTime?    @map("released_at")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  membership     Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([membershipId])
  @@map("billing_seat_assignments")
}

/// Modeled directly on AiUsageLog's shape — a never-throws append-only
/// meter. periodStart/End are denormalized onto every row (not derived
/// via a join to Subscription) so "sum this org's usage for the current
/// period" is a single indexed range scan.
model UsageRecord {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  featureKey     String       @map("feature_key")
  /// BigInt — byte-denominated usage (storage/uploads) exceeds a 32-bit Int's range.
  quantity       BigInt       @default(1)
  metadata       Json         @default("{}")
  periodStart    DateTime     @map("period_start")
  periodEnd      DateTime     @map("period_end")
  recordedAt     DateTime     @default(now()) @map("recorded_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, featureKey, periodStart])
  @@index([recordedAt])
  @@map("billing_usage_records")
}

/// Nightly rollup of UsageRecord so usage charts don't re-aggregate raw
/// rows on every request.
model UsageSnapshot {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  featureKey     String       @map("feature_key")
  periodStart    DateTime     @map("period_start")
  periodEnd      DateTime     @map("period_end")
  totalQuantity  BigInt       @map("total_quantity")
  computedAt     DateTime     @default(now()) @map("computed_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, featureKey, periodStart])
  @@index([organizationId])
  @@map("billing_usage_snapshots")
}

model Invoice {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @map("organization_id") @db.Uuid
  billingAccountId String         @map("billing_account_id") @db.Uuid
  stripeInvoiceId  String?        @unique @map("stripe_invoice_id")
  status           InvoiceStatus  @default(DRAFT)
  amountDue        Decimal        @default(0) @map("amount_due") @db.Decimal(12, 2)
  amountPaid       Decimal        @default(0) @map("amount_paid") @db.Decimal(12, 2)
  amountRemaining  Decimal        @default(0) @map("amount_remaining") @db.Decimal(12, 2)
  currency         String         @default("usd")
  periodStart      DateTime?      @map("period_start")
  periodEnd        DateTime?      @map("period_end")
  dueDate          DateTime?      @map("due_date")
  paidAt           DateTime?      @map("paid_at")
  hostedInvoiceUrl String?        @map("hosted_invoice_url")
  pdfUrl           String?        @map("pdf_url")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  items            InvoiceItem[]
  payments         Payment[]

  @@index([organizationId])
  @@index([billingAccountId])
  @@index([status])
  @@map("billing_invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
