generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL is the runtime (pooled) connection — safe for Neon's
  // PgBouncer endpoint. directUrl is read only by the Prisma migration
  // engine (`prisma migrate deploy`, `prisma migrate dev`), which needs a
  // direct, unpooled connection: transaction-mode PgBouncer doesn't support
  // the prepared statements / advisory locks migrations rely on. DIRECT_URL
  // must be set in every environment that ever runs a migration — for a
  // non-pooled database (local docker-compose, CI's ephemeral Postgres)
  // it's simply the same value as DATABASE_URL; for Neon it's the separate
  // unpooled connection string from the Neon dashboard.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CompanySize {
  JUST_ME
  EMPLOYEES_2_10
  EMPLOYEES_11_50
  EMPLOYEES_51_200
  EMPLOYEES_201_500
  EMPLOYEES_501_1000
  EMPLOYEES_1000_PLUS
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

/// v2.3 Developer Platform — see User.type above.
enum UserType {
  HUMAN
  SERVICE_ACCOUNT
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum ToolExecutionStatus {
  RUNNING
  SUCCEEDED
  FAILED
  TIMED_OUT
}

enum AgentRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  TIMED_OUT
  WAITING_APPROVAL
}

enum AgentActionApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum AiRequestType {
  CHAT
  CONVERSATION_MESSAGE
  AGENT_RUN
  TOOL_EXECUTION
  KNOWLEDGE_EMBEDDING
}

enum AgentRunStepType {
  PLAN
  REASONING
  TOOL_CALL
  TOOL_RESULT
  TOOL_ERROR
  FINAL_ANSWER
  DELEGATION_START
  DELEGATION_RESULT
}

enum AgentMessageType {
  REQUEST
  RESPONSE
  STATUS
  OBSERVATION
  COMPLETION
}

enum SalesCompanyStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum SalesLeadStatus {
  NEW
  QUALIFIED
  NURTURING
  DISQUALIFIED
  CONVERTED
}

enum SalesOpportunityStage {
  DISCOVERY
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum SalesActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
}

model Organization {
  id                      String                   @id @default(uuid()) @db.Uuid
  name                    String
  slug                    String                   @unique
  logoUrl                 String?                  @map("logo_url")
  email                   String?
  website                 String?
  industry                String?
  country                 String?
  state                   String?
  city                    String?
  companySize             CompanySize?             @map("company_size")
  primaryGoals            String[]                 @default([]) @map("primary_goals")
  currency                String?
  language                String?
  phone                   String?
  timezone                String                   @default("UTC")
  status                  OrganizationStatus       @default(ACTIVE)
  settings                Json                     @default("{}")
  onboardingCompletedAt   DateTime?                @map("onboarding_completed_at")
  /// v2.2 Enterprise Organization Hierarchy — metadata tag ONLY, read
  /// exclusively by the platform-admin-gated cross-org reporting
  /// endpoints (src/modules/platform/reporting/). Never consulted by
  /// TenantContextService or the Prisma tenant-scoping extension — every
  /// subsidiary remains a fully isolated tenant for all normal traffic.
  parentOrganizationId    String?                  @map("parent_organization_id") @db.Uuid
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  deletedAt               DateTime?                @map("deleted_at")
  parentOrganization      Organization?            @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id], onDelete: SetNull)
  subsidiaries            Organization[]           @relation("OrganizationHierarchy")
  businessUnits           BusinessUnit[]
  departments             Department[]
  teams                   Team[]
  costCenters             CostCenter[]
  memberships             Membership[]
  conversations           Conversation[]
  memories                Memory[]
  agents                  Agent[]
  aiUsageLogs             AiUsageLog[]
  salesCompanies          SalesCompany[]
  salesContacts           SalesContact[]
  salesLeads              SalesLead[]
  salesOpportunities      SalesOpportunity[]
  salesActivities         SalesActivity[]
  knowledgeSources        KnowledgeSource[]
  knowledgeEntities       KnowledgeEntity[]
  workflows               Workflow[]
  integrationConnections  IntegrationConnection[]
  invitations             Invitation[]
  commsChannelConnections CommsChannelConnection[]
  commsConversations      CommsConversation[]
  commsConversationLabels ConversationLabel[]
  attachments             Attachment[]
  workflowTemplates       WorkflowTemplate[]
  workflowSecrets         WorkflowSecret[]
  workflowWebhooks        WorkflowWebhook[]
  workflowVariables       WorkflowVariable[]
  billingAccount          BillingAccount?
  subscriptions           Subscription[]
  seatAssignments         SeatAssignment[]
  usageRecords            UsageRecord[]
  usageSnapshots          UsageSnapshot[]
  invoices                Invoice[]
  payments                Payment[]
  paymentMethods          PaymentMethod[]
  discounts               Discount[]
  taxProfile              TaxProfile?
  checkoutSessions        CheckoutSession[]
  portalSessions          CustomerPortalSession[]
  identityProviders       IdentityProvider[]
  scimTokens              ScimToken[]
  scimProvisionJobs       ScimProvisionJob[]
  auditExports            AuditExport[]
  legalHolds              LegalHold[]
  retentionPolicies       RetentionPolicy[]
  consentRecords          ConsentRecord[]
  sessions                Session[]
  trustedDevices          TrustedDevice[]
  apiKeys                 ApiKey[]
  brandTheme              BrandTheme?
  customDomains           CustomDomain[]
  serviceAccounts         ServiceAccount[]
  oauthApplications       OAuthApplication[]
  webhookEndpoints        WebhookEndpoint[]
  marketplaceApps         MarketplaceApp[]         @relation("MarketplaceAppDeveloper")
  marketplaceInstalls     MarketplaceInstall[]     @relation("MarketplaceInstallOrganization")
  developerConnectAccount DeveloperConnectAccount?

  @@index([status])
  @@index([parentOrganizationId])
  @@map("organizations")
}

model User {
  id                      String                @id @default(uuid()) @db.Uuid
  email                   String                @unique
  passwordHash            String?               @map("password_hash")
  firstName               String                @map("first_name")
  lastName                String                @map("last_name")
  avatarUrl               String?               @map("avatar_url")
  phoneNumber             String?               @map("phone_number")
  jobTitle                String?               @map("job_title")
  status                  UserStatus            @default(ACTIVE)
  /// v2.3 Developer Platform — HUMAN for every user before this column
  /// existed and every normal signup; SERVICE_ACCOUNT marks the synthetic
  /// User row backing a ServiceAccount (see that model below), so
  /// human-only surfaces (team member lists, "invite a teammate" flows,
  /// @mentions, etc.) can filter these out without inferring it from an
  /// email-address convention.
  type                    UserType              @default(HUMAN)
  isPlatformAdmin         Boolean               @default(false) @map("is_platform_admin")
  lastLoginAt             DateTime?             @map("last_login_at")
  emailVerifiedAt         DateTime?             @map("email_verified_at")
  notificationPreferences Json                  @default("{}") @map("notification_preferences")
  /// v2.2 Security Center — TOTP MFA enrollment. `mfaSecret` is encrypted at
  /// rest via EncryptionService (never stored/returned in plaintext);
  /// `mfaEnabled` only flips true after a successful verify-setup, so a
  /// pending, unconfirmed enrollment never gates login.
  mfaEnabled              Boolean               @default(false) @map("mfa_enabled")
  mfaSecret               String?               @map("mfa_secret")
  /// sha256 hashes of one-time backup codes (same hash-and-compare
  /// convention as RefreshToken/ApiKey) — each is cleared from the array the
  /// moment it's consumed, enforcing single use.
  mfaBackupCodesHash      String[]              @default([]) @map("mfa_backup_codes_hash")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  deletedAt               DateTime?             @map("deleted_at")
  memberships             Membership[]
  refreshTokens           RefreshToken[]
  verificationTokens      VerificationToken[]
  conversations           Conversation[]
  memories                Memory[]
  aiUsageLogs             AiUsageLog[]
  sentInvitations         Invitation[]          @relation("InvitationInvitedBy")
  acceptedInvitations     Invitation[]          @relation("InvitationAcceptedBy")
  notifications           Notification[]
  attachments             Attachment[]
  consentRecords          ConsentRecord[]
  sessions                Session[]
  trustedDevices          TrustedDevice[]
  personalAccessTokens    PersonalAccessToken[]
  serviceAccount          ServiceAccount?

  @@index([status])
  @@index([type])
  @@map("users")
}

model Conversation {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  title          String
  model          String
  provider       String
  pinned         Boolean         @default(false)
  archived       Boolean         @default(false)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]
  toolExecutions ToolExecution[]
  memories       Memory[]
  memoryAccesses MemoryAccess[]
  agentRuns      AgentRun[]
  aiUsageLogs    AiUsageLog[]
  workflowRuns   WorkflowRun[]

  @@index([organizationId])
  @@index([userId])
  @@index([archived])
  @@index([pinned])
  @@index([deletedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String
  metadata       Json         @default("{}")
  tokenUsage     Json         @default("{}") @map("token_usage")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@map("messages")
}

model ToolExecution {
  id             String              @id @default(uuid()) @db.Uuid
  conversationId String              @map("conversation_id") @db.Uuid
  toolName       String              @map("tool_name")
  input          Json                @default("{}")
  output         Json                @default("{}")
  status         ToolExecutionStatus
  startedAt      DateTime            @map("started_at")
  completedAt    DateTime?           @map("completed_at")
  durationMs     Int?                @map("duration_ms")
  error          String?
  createdAt      DateTime            @default(now()) @map("created_at")
  conversation   Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([toolName])
  @@index([status])
  @@index([createdAt])
  @@map("tool_executions")
}

model Memory {
  id             String                       @id @default(uuid()) @db.Uuid
  organizationId String                       @map("organization_id") @db.Uuid
  userId         String                       @map("user_id") @db.Uuid
  conversationId String                       @map("conversation_id") @db.Uuid
  category       String
  importance     Float
  content        String
  embeddingId    String?                      @map("embedding_id")
  /// Content embedding for semantic memory scoring — same pgvector
  /// pattern as KnowledgeChunk.embedding (Unsupported since Prisma has no
  /// native vector type; all reads/writes go through raw SQL in
  /// MemoryRepository). Computed once at capture time in
  /// MemoryService.captureConversationMemories.
  embedding      Unsupported("vector(1536)")?
  metadata       Json                         @default("{}")
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")
  deletedAt      DateTime?                    @map("deleted_at")
  organization   Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation                 @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  accesses       MemoryAccess[]

  @@index([organizationId])
  @@index([userId])
  @@index([conversationId])
  @@index([category])
  @@index([importance])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("memories")
}

model MemoryAccess {
  id             String       @id @default(uuid()) @db.Uuid
  memoryId       String       @map("memory_id") @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  accessedAt     DateTime     @default(now()) @map("accessed_at")
  memory         Memory       @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@index([conversationId])
  @@index([accessedAt])
  @@map("memory_accesses")
}

model Agent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  description    String
  systemPrompt   String       @map("system_prompt")
  provider       String
  model          String
  configuration  Json         @default("{}")
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs           AgentRun[]
  aiUsageLogs    AiUsageLog[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([enabled])
  @@index([deletedAt])
  @@map("agents")
}

model AgentRun {
  id             String                @id @default(uuid()) @db.Uuid
  agentId        String                @map("agent_id") @db.Uuid
  conversationId String                @map("conversation_id") @db.Uuid
  parentRunId    String?               @map("parent_run_id") @db.Uuid
  rootRunId      String?               @map("root_run_id") @db.Uuid
  depth          Int                   @default(0)
  status         AgentRunStatus
  input          Json                  @default("{}")
  output         Json                  @default("{}")
  currentStep    Int                   @default(0) @map("current_step")
  iterationCount Int                   @default(0) @map("iteration_count")
  toolCallCount  Int                   @default(0) @map("tool_call_count")
  startedAt      DateTime              @map("started_at")
  completedAt    DateTime?             @map("completed_at")
  durationMs     Int?                  @map("duration_ms")
  tokenUsage     Json                  @default("{}") @map("token_usage")
  error          String?
  createdAt      DateTime              @default(now()) @map("created_at")
  agent          Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation   Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parentRun      AgentRun?             @relation("AgentRunHierarchy", fields: [parentRunId], references: [id], onDelete: Cascade)
  childRuns      AgentRun[]            @relation("AgentRunHierarchy")
  aiUsageLogs    AiUsageLog[]
  steps          AgentRunStep[]
  sentMessages   AgentMessage[]
  approvals      AgentActionApproval[]

  @@index([agentId])
  @@index([conversationId])
  @@index([parentRunId])
  @@index([rootRunId])
  @@index([status])
  @@index([createdAt])
  @@map("agent_runs")
}

/// A pending/decided human approval gate for a sensitive AI tool call —
/// mirrors WorkflowApproval's shape/role for the Workflow engine, applied
/// to agent tool calls instead of workflow steps. Created the moment
/// AiGatewayService.executeTool() finds a mutating tool with no explicit
/// permission override; AgentLoopService pauses the run to
/// WAITING_APPROVAL until this is decided.
model AgentActionApproval {
  id             String                    @id @default(uuid()) @db.Uuid
  organizationId String                    @map("organization_id") @db.Uuid
  agentRunId     String                    @map("agent_run_id") @db.Uuid
  toolName       String                    @map("tool_name")
  input          Json                      @default("{}")
  status         AgentActionApprovalStatus @default(PENDING)
  approverUserId String?                   @map("approver_user_id") @db.Uuid
  comment        String?
  expiresAt      DateTime?                 @map("expires_at")
  decidedAt      DateTime?                 @map("decided_at")
  createdAt      DateTime                  @default(now()) @map("created_at")
  agentRun       AgentRun                  @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agentRunId])
  @@index([status])
  @@map("agent_action_approvals")
}

model AgentRunStep {
  id         String           @id @default(uuid()) @db.Uuid
  agentRunId String           @map("agent_run_id") @db.Uuid
  stepNumber Int              @map("step_number")
  type       AgentRunStepType
  summary    String
  toolName   String?          @map("tool_name")
  input      Json?
  output     Json?
  createdAt  DateTime         @default(now()) @map("created_at")
  agentRun   AgentRun         @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId])
  @@index([stepNumber])
  @@index([type])
  @@map("agent_run_steps")
}

model AgentMessage {
  id             String           @id @default(uuid()) @db.Uuid
  rootRunId      String           @map("root_run_id") @db.Uuid
  fromAgentRunId String           @map("from_agent_run_id") @db.Uuid
  toAgentRunId   String?          @map("to_agent_run_id") @db.Uuid
  type           AgentMessageType
  content        String
  payload        Json             @default("{}")
  createdAt      DateTime         @default(now()) @map("created_at")
  fromAgentRun   AgentRun         @relation(fields: [fromAgentRunId], references: [id], onDelete: Cascade)

  @@index([rootRunId])
  @@index([fromAgentRunId])
  @@index([toAgentRunId])
  @@index([type])
  @@map("agent_messages")
}

model AiUsageLog {
  id               String        @id @default(uuid()) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  conversationId   String?       @map("conversation_id") @db.Uuid
  agentId          String?       @map("agent_id") @db.Uuid
  agentRunId       String?       @map("agent_run_id") @db.Uuid
  requestType      AiRequestType @map("request_type")
  provider         String?
  model            String?
  toolName         String?       @map("tool_name")
  inputTokens      Int           @default(0) @map("input_tokens")
  outputTokens     Int           @default(0) @map("output_tokens")
  totalTokens      Int           @default(0) @map("total_tokens")
  estimatedCostUsd Decimal       @default(0) @map("estimated_cost_usd") @db.Decimal(12, 6)
  durationMs       Int?          @map("duration_ms")
  succeeded        Boolean       @default(true)
  errorMessage     String?       @map("error_message")
  createdAt        DateTime      @default(now()) @map("created_at")
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent            Agent?        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentRun         AgentRun?     @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([conversationId])
  @@index([agentId])
  @@index([agentRunId])
  @@index([requestType])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

model VerificationToken {
  id        String                @id @default(uuid()) @db.Uuid
  userId    String                @map("user_id") @db.Uuid
  tokenHash String                @map("token_hash")
  type      VerificationTokenType
  expiresAt DateTime              @map("expires_at")
  usedAt    DateTime?             @map("used_at")
  createdAt DateTime              @default(now()) @map("created_at")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([type])
  @@map("verification_tokens")
}

model AuditLog {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  requestId        String   @map("request_id")
  action           String
  resource         String
  resourceId       String?  @map("resource_id") @db.Uuid
  metadata         Json     @default("{}")
  /// v2.2 Compliance Center — tamper-evident hash chain, computed at write
  /// time inside the same transaction as the insert (see AuditRepository.write).
  /// previousHash is the `hash` of the immediately preceding row for the same
  /// organizationId (null for the first row in an org's chain); hash is
  /// sha256(previousHash + canonical row payload). Both nullable/additive so
  /// rows written before this feature existed simply have no chain entry —
  /// GET /compliance/audit/verify treats a null hash as "unchained" and skips
  /// it rather than reporting a false tamper break.
  previousHash     String?  @map("previous_hash")
  hash             String?  @map("hash")
  /// v2.2 Customer Success (Phase 9) — set only when this row was written
  /// while a SupportSession (impersonation) was active for the current
  /// request; null for every ordinary action. `userId` above is always
  /// the platform admin's own real user id in that case (impersonation
  /// never fabricates another user's identity), so this column exists
  /// purely to make "was this actually support, and under what reason"
  /// independently queryable via a join to SupportSession.
  supportSessionId String?  @map("support_session_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@index([requestId])
  @@index([organizationId, createdAt])
  @@index([supportSessionId])
  @@map("audit_logs")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  /// v2.2 Security Center — additive link to the stable Session this token
  /// belongs to. Nullable so pre-existing rows (issued before this column
  /// existed) and token issuance paths that don't pass a sessionId
  /// (register/switchOrganization/SSO JIT/invitation-accept — unchanged by
  /// this phase) keep working exactly as before. Rotation (POST /auth/refresh)
  /// carries the same sessionId forward onto the new row so a revoked
  /// Session immediately invalidates every refresh token under it.
  sessionId String?   @map("session_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tokenHash])
  @@index([sessionId])
  @@map("refresh_tokens")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  key             String           @unique
  name            String
  description     String?
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  memberships     Membership[]
  rolePermissions RolePermission[]
  invitations     Invitation[]

  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  key             String           @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Membership {
  id                              String            @id @default(uuid()) @db.Uuid
  organizationId                  String            @map("organization_id") @db.Uuid
  userId                          String            @map("user_id") @db.Uuid
  roleId                          String            @map("role_id") @db.Uuid
  joinedAt                        DateTime          @default(now()) @map("joined_at")
  status                          MembershipStatus  @default(ACTIVE)
  /// Set when this membership was created by SSO Just-in-Time provisioning
  /// (Phase 1) or a SCIM sync (Phase 2), rather than manual invitation —
  /// purely informational, carries no access implication.
  provisionedByIdentityProviderId String?           @map("provisioned_by_identity_provider_id") @db.Uuid
  /// v2.2 Enterprise Organization Hierarchy — intra-tenant tagging only,
  /// all optional and all scoped to the same organization as the
  /// membership itself (enforced in the service layer, not the DB).
  businessUnitId                  String?           @map("business_unit_id") @db.Uuid
  departmentId                    String?           @map("department_id") @db.Uuid
  teamId                          String?           @map("team_id") @db.Uuid
  organization                    Organization      @relation(fields: [organizationId], references: [id])
  user                            User              @relation(fields: [userId], references: [id])
  role                            Role              @relation(fields: [roleId], references: [id])
  provisionedByIdentityProvider   IdentityProvider? @relation("MembershipProvisionedBy", fields: [provisionedByIdentityProviderId], references: [id], onDelete: SetNull)
  businessUnit                    BusinessUnit?     @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  department                      Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team                            Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  seatAssignments                 SeatAssignment[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([provisionedByIdentityProviderId])
  @@index([businessUnitId])
  @@index([departmentId])
  @@index([teamId])
  @@map("memberships")
}

