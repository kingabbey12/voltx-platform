# ── Core ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Database (Postgres + pgvector) ──────────────────────────────────────
DATABASE_URL=postgresql://voltx:voltx@localhost:5433/voltx
# Direct (unpooled) connection used only by `prisma migrate deploy`/`dev` —
# transaction-mode PgBouncer (e.g. Neon's pooled endpoint) can't run
# migrations. Same value as DATABASE_URL for a non-pooled database; on Neon,
# use the separate "direct connection" string from the Neon dashboard.
DIRECT_URL=postgresql://voltx:voltx@localhost:5433/voltx
# Optional read-replica connection string (PrismaService.replica routing).
# Leave unset unless you actually have a replica — most environments do.
DATABASE_REPLICA_URL=
DATABASE_CONNECTION_LIMIT=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_QUERY_LOGGING_ENABLED=false
DATABASE_SLOW_QUERY_THRESHOLD_MS=500
DATABASE_TRANSACTION_MAX_WAIT_MS=5000
DATABASE_TRANSACTION_TIMEOUT_MS=10000

# ── Auth (JWT) ───────────────────────────────────────────────────────────
# Generate a real secret for anything beyond local dev, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-in-production-use-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m

# ── Security / networking ───────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=120
# Tighter limit applied to auth endpoints only (login/register/verify-email/password-reset)
AUTH_RATE_LIMIT_TTL_SECONDS=60
AUTH_RATE_LIMIT_LIMIT=10
REQUEST_BODY_LIMIT=1mb
# Comma-separated browser origins allowed to call this API with credentials.
# Leave empty to keep CORS closed (native/mobile clients are unaffected either way).
CORS_ALLOWED_ORIGINS=
# Number of trusted reverse-proxy hops in front of this API (e.g. 1 behind a
# single load balancer). Governs how `request.ip` is resolved from
# X-Forwarded-For — used by the Security Center's IpAllowlistGuard. Leave at
# 0 (trust nothing) unless you know exactly how many hops are in front of you.
TRUSTED_PROXY_COUNT=0

# ── Security Center (MFA / API keys) ────────────────────────────────────
MFA_TOTP_ISSUER=Voltx
MFA_CHALLENGE_EXPIRES_IN=5m
MFA_BACKUP_CODE_COUNT=10
MFA_TRUSTED_DEVICE_DEFAULT_DAYS=30
API_KEY_PREFIX=vk
PERSONAL_ACCESS_TOKEN_PREFIX=vpat
SERVICE_ACCOUNT_TOKEN_PREFIX=vsa

# ── OAuth 2.0 authorization server (v2.3 — Voltx as an OAuth provider for
# third-party apps, distinct from the social-login OAUTH_*_CLIENT_ID vars
# under Integrations below, which are for connecting *to* Google/Microsoft/
# GitHub as a data source) ────────────────────────────────────────────────
OAUTH_CLIENT_SECRET_PREFIX=vcs
OAUTH_ACCESS_TOKEN_PREFIX=voat
OAUTH_REFRESH_TOKEN_PREFIX=vort
OAUTH_AUTHORIZATION_CODE_PREFIX=vac
OAUTH_AUTHORIZATION_CODE_TTL_SECONDS=60
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# ── Outbound webhooks (v2.3) ─────────────────────────────────────────────
WEBHOOK_MAX_DELIVERY_ATTEMPTS=6
WEBHOOK_RETRY_BASE_DELAY_MS=5000
WEBHOOK_REQUEST_TIMEOUT_MS=10000

# Comma-separated emails granted cross-organization Super Admin Billing
# Console access on their next login. Empty = no platform admins.
PLATFORM_ADMIN_EMAILS=

# ── Observability ────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=voltx-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# Error reporting is a no-op until SENTRY_DSN is set.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0

# ── Caching ──────────────────────────────────────────────────────────────
# Optional shared cache for the knowledge-retrieval embedding cache. When
# disabled, an in-process cache is used instead (fine for a single instance).
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ── AI Gateway ───────────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-5-mini
AI_MAX_RETRIES=2
AI_RETRY_BASE_DELAY_MS=250
AI_RATE_LIMIT_REQUESTS_PER_MINUTE=120
AI_AGENT_LOOP_MAX_ITERATIONS=8
AI_AGENT_LOOP_MAX_TOOL_CALLS=12
AI_AGENT_LOOP_TIMEOUT_MS=120000
AI_MULTI_AGENT_MAX_AGENTS=10
AI_MULTI_AGENT_MAX_DEPTH=3
AI_MULTI_AGENT_MAX_PARALLEL=4
AI_MULTI_AGENT_TIMEOUT_MS=300000
# Comma-separated hostname allowlist for the AI runtime's outbound HTTP tool
# (extensions/agent tools that call arbitrary URLs). Empty = the tool is
# disabled entirely rather than allowed to reach any host.
AI_HTTP_TOOL_ALLOWED_HOSTS=

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

GOOGLE_AI_ENABLED=false
GOOGLE_AI_API_KEY=
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Knowledge Graph ──────────────────────────────────────────────────────
KNOWLEDGE_EMBEDDING_PROVIDER=openai
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
KNOWLEDGE_EMBEDDING_DIMENSIONS=1536
KNOWLEDGE_EMBEDDING_BATCH_SIZE=64
KNOWLEDGE_CHUNK_SIZE_TOKENS=400
KNOWLEDGE_CHUNK_OVERLAP_TOKENS=60
KNOWLEDGE_RETRIEVAL_TOP_K=8
KNOWLEDGE_RETRIEVAL_MAX_TOP_K=50
KNOWLEDGE_RETRIEVAL_SEMANTIC_WEIGHT=0.65
KNOWLEDGE_RETRIEVAL_KEYWORD_WEIGHT=0.35
KNOWLEDGE_RETRIEVAL_MIN_CONFIDENCE=0.15
KNOWLEDGE_RETRIEVAL_CONTEXT_TOKEN_BUDGET=2000
KNOWLEDGE_RETRIEVAL_GRAPH_HOPS=1
KNOWLEDGE_RETRIEVAL_CACHE_TTL_MS=30000

# ── Organization invitations ─────────────────────────────────────────────
# Deep link (or web URL) that opens the "accept invitation" screen; ?token=... is appended
INVITATIONS_ACCEPT_BASE_URL=voltx://invitations/accept

# ── Transactional email (Resend) ─────────────────────────────────────────
# Powers email verification and password reset emails. Without it, those
# tokens are still issued and valid — MailService just logs and no-ops
# instead of sending, so the emails never arrive. Get a key at resend.com.
RESEND_API_KEY=
MAIL_FROM_ADDRESS=Voltx <noreply@usevoltx.com>
# Base URL of the web app that hosts /verify-email and /reset-password —
# used to build the links inside those emails.
WEB_APP_BASE_URL=https://app.usevoltx.com

# ── Integrations ─────────────────────────────────────────────────────────
# Required in every environment — encrypts every stored OAuth token/API
# key/webhook secret at rest. The app refuses to start without it.
# Generate with: openssl rand -base64 32
INTEGRATIONS_ENCRYPTION_KEY=
# Set only while rotating to a new INTEGRATIONS_ENCRYPTION_KEY — decrypt
# falls back to this key so already-encrypted rows keep working during the
# rotation window. See docs/operations/key-rotation.md.
INTEGRATIONS_ENCRYPTION_KEY_PREVIOUS=
INTEGRATIONS_WEBHOOK_BASE_URL=
INTEGRATIONS_POLL_INTERVAL_MS=300000
INTEGRATIONS_MAX_RETRIES=3
INTEGRATIONS_RETRY_BASE_DELAY_MS=500
INTEGRATIONS_RATE_LIMIT_REQUESTS_PER_MINUTE=60

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common

SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# WhatsApp Business Platform webhook (communications module) — App Secret
# verifies inbound webhook signatures; the verify token is the arbitrary
# string you register in Meta's webhook config for the subscription handshake.
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Marketplace (v2.3 Developer Platform) — its own Stripe Connect webhook
# endpoint/secret, separate from STRIPE_WEBHOOK_SECRET above.
MARKETPLACE_PLATFORM_FEE_BPS=2000
MARKETPLACE_STRIPE_WEBHOOK_SECRET=
MARKETPLACE_CONNECT_RETURN_BASE_URL=

# ── File attachments ─────────────────────────────────────────────────────
# "local" (default, disk storage under ATTACHMENTS_LOCAL_ROOT_DIR — fine for
# a single instance / dev) or "s3" (S3 or an S3-compatible provider).
ATTACHMENTS_STORAGE_PROVIDER=local
ATTACHMENTS_LOCAL_ROOT_DIR=.attachments-storage
ATTACHMENTS_MAX_FILE_SIZE_BYTES=26214400
ATTACHMENTS_SIGNED_URL_TTL_SECONDS=900
# Required when ATTACHMENTS_STORAGE_PROVIDER=s3:
ATTACHMENTS_S3_BUCKET=
ATTACHMENTS_S3_REGION=
ATTACHMENTS_S3_ACCESS_KEY_ID=
ATTACHMENTS_S3_SECRET_ACCESS_KEY=
# Optional — set for R2/Supabase/MinIO/any S3-compatible endpoint; leave
# unset for real AWS S3.
ATTACHMENTS_S3_ENDPOINT=
ATTACHMENTS_S3_FORCE_PATH_STYLE=false

# Optional ClamAV virus scanning for uploaded attachments. Unset host = scanning
# is skipped entirely rather than treated as a boot failure (see 2e4e447).
CLAMAV_HOST=
CLAMAV_PORT=3310
