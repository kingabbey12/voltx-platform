{
  "title": "Voltx — API Overview",
  "uid": "voltx-api-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["voltx", "api"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(voltx_http_requests_total[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx) by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(voltx_http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 request duration (ms) by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (route, le) (rate(voltx_http_request_duration_ms_bucket[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "BullMQ queue depth by state",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "voltx_queue_depth",
          "legendFormat": "{{queue}} — {{state}}"
        }
      ]
    }
  ]
}
